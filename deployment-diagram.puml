@startuml Deployment_Diagram

' ============================================
' DEPLOYMENT DIAGRAM
' Bug Bounty and Its Simulation Platform
' Team: Niway Tadesse, Abraham Asimamaw, Melkamu Tesfa
' Advisor: Yosef Worku
' Docker-based Deployment Architecture
' ============================================

!define NODE node
!define ARTIFACT artifact

skinparam node {
    BackgroundColor<<Client>> LightBlue
    BackgroundColor<<Docker>> LightGreen
    BackgroundColor<<External>> Pink
    BackgroundColor<<Cache>> Orange
    BackgroundColor<<Database>> LightCyan
}

skinparam artifact {
    BackgroundColor<<UI>> LightBlue
    BackgroundColor<<Service>> LightGreen
    BackgroundColor<<Worker>> Yellow
    BackgroundColor<<DB>> LightCyan
}

title Bug Bounty and Its Simulation Platform - Deployment Diagram (Docker Local)

' ============================================
' CLIENT LAYER
' ============================================

node "Clients" <<Client>> {
    artifact "Researcher Portal\n(Next.js)" as researcher_portal
    artifact "Simulation/Training Interface\n(Next.js)" as simulation_interface
    artifact "Organization Portal\n(Next.js)" as organization_portal
    artifact "Admin/Triage Portal\n(Next.js)" as admin_portal
    artifact "Leaderboard/Analytics\n(Next.js)" as leaderboard_portal
}

' ============================================
' NGINX LOAD BALANCER (DOCKER)
' ============================================

node "Nginx Load Balancer (Docker)" <<Docker>> {
    artifact "Nginx\n(Reverse Proxy)\nPort: 80, 443" as nginx_lb
}

' ============================================
' VARNISH CACHE LAYER (DOCKER)
' ============================================

node "Varnish Cache (Docker)" <<Cache>> {
    artifact "Varnish Cache\n(HTTP Cache)\nPort: 6081" as varnish_cache
}

' ============================================
' MICROSERVICES LAYER (DOCKER)
' ============================================

node "Microservices (Docker)" <<Docker>> {
    artifact "Bug Bounty Engine Service\n(FastAPI)\nPort: 8001" as bug_bounty_service
    artifact "PTaaS Engine Service\n(FastAPI)\nPort: 8002" as ptaas_service
    artifact "AI Red Teaming Service\n(FastAPI)\nPort: 8003" as ai_red_service
    artifact "Simulation/Challenge Engine Service\n(FastAPI)\nPort: 8004" as simulation_service
    artifact "Researcher Matching Service\n(FastAPI)\nPort: 8005" as matching_service
    artifact "Reward & Commission Service\n(FastAPI)\nPort: 8006" as reward_service
    artifact "Notification Service\n(FastAPI)\nPort: 8007" as notification_service
    artifact "SSDLC Integration Service\n(FastAPI)\nPort: 8008" as ssdlc_service
}

' ============================================
' WORKER LAYER (DOCKER)
' ============================================

node "Worker Layer (Docker)" <<Docker>> {
    artifact "Celery Workers\n(Background Tasks)\nPort: N/A" as celery_workers
    artifact "Redis Cache/Broker\n(Task Queue)\nPort: 6379" as redis_broker
}

' ============================================
' FILE STORAGE LAYER (DOCKER)
' ============================================

node "File Storage (Docker)" <<Docker>> {
    artifact "MinIO\n(S3-Compatible Storage)\nPort: 9000, 9001" as minio_storage
}

' ============================================
' DATABASE LAYER (DOCKER)
' ============================================

node "Database Layer (Docker)" <<Database>> {
    artifact "PostgreSQL\n(Relational + JSONB)\nPort: 5432" as postgresql_db
}

' ============================================
' EXTERNAL SERVICES
' ============================================

node "External Services" <<External>> {
    artifact "Payment Gateway\n(Telebirr, CBE Birr)" as payment_gateway
    artifact "Email/Messaging Service\n(SMTP, Twilio)" as messaging_service
    artifact "CI/CD & Repo Integration\n(GitHub, GitLab)" as cicd_integration
}

' ============================================
' CONNECTIONS
' ============================================

' Clients to Nginx Load Balancer
researcher_portal --> nginx_lb : HTTPS (443)
simulation_interface --> nginx_lb : HTTPS/WSS (443)
organization_portal --> nginx_lb : HTTPS (443)
admin_portal --> nginx_lb : HTTPS (443)
leaderboard_portal --> nginx_lb : HTTPS (443)

' Nginx to Varnish Cache
nginx_lb --> varnish_cache : HTTP (6081)

' Varnish Cache to Microservices
varnish_cache --> bug_bounty_service : HTTP (8001)
varnish_cache --> ptaas_service : HTTP (8002)
varnish_cache --> ai_red_service : HTTP (8003)
varnish_cache --> simulation_service : HTTP/WSS (8004)
varnish_cache --> matching_service : HTTP (8005)
varnish_cache --> reward_service : HTTP (8006)
varnish_cache --> notification_service : HTTP/WSS (8007)
varnish_cache --> ssdlc_service : HTTP (8008)

' Microservices to Worker Layer
bug_bounty_service --> redis_broker : Redis (6379)
ptaas_service --> redis_broker : Redis (6379)
ai_red_service --> redis_broker : Redis (6379)
matching_service --> redis_broker : Redis (6379)
notification_service --> celery_workers : Task Queue
reward_service --> celery_workers : Task Queue
ssdlc_service --> celery_workers : Task Queue

' Microservices to File Storage
bug_bounty_service --> minio_storage : S3 API (9000)
ptaas_service --> minio_storage : S3 API (9000)
simulation_service --> minio_storage : S3 API (9000)
ssdlc_service --> minio_storage : S3 API (9000)

' Microservices to Database
bug_bounty_service --> postgresql_db : PostgreSQL (5432)
ptaas_service --> postgresql_db : PostgreSQL (5432)
ai_red_service --> postgresql_db : PostgreSQL (5432)
simulation_service --> postgresql_db : PostgreSQL (5432)
matching_service --> postgresql_db : PostgreSQL (5432)
reward_service --> postgresql_db : PostgreSQL (5432)
notification_service --> postgresql_db : PostgreSQL (5432)

' Worker Layer to External Services
celery_workers --> payment_gateway : HTTPS/API
celery_workers --> messaging_service : SMTP/API
celery_workers --> cicd_integration : HTTPS/API

' Worker Layer to Database
celery_workers --> postgresql_db : PostgreSQL (5432)

' Worker Layer to File Storage
celery_workers --> minio_storage : S3 API (9000)

' ============================================
' NOTES & ANNOTATIONS
' ============================================

note top of nginx_lb
  **Entry Point**
  • SSL/TLS termination
  • Load balancing
  • Rate limiting
  • Security headers
  • Reverse proxy
end note

note top of varnish_cache
  **HTTP Caching Layer**
  • Caches API responses
  • Reduces backend load
  • Cache invalidation
  • Performance optimization
end note

note right of redis_broker
  **Async Processing**
  • Task queue management
  • Session storage
  • Application cache
  • Pub/Sub messaging
  • Rate limiting store
end note

note right of minio_storage
  **File Storage**
  • Report attachments
  • Screenshots/Videos
  • Documents
  • S3-compatible API
  • Local development
  • Migrates to AWS S3
    in production
end note

note bottom of postgresql_db
  **Database Features**
  • JSONB for unstructured data
  • Full-text search
  • Row-level security
  • Separate schemas:
    - Production data
    - Simulation data (isolated)
  • ACID transactions
end note

note bottom of payment_gateway
  **Ethiopian Payment Systems**
  • Telebirr Mobile Money
  • CBE Birr Digital Wallet
  • Bank Transfer APIs
  • Webhook integration
end note

note top of simulation_service
  **Isolated Simulation**
  • Separate database schema
  • No real payments
  • Practice environment
  • OWASP Juice Shop
  • Can be deployed separately
end note

note bottom of postgresql_db
  **Docker Networks**
  • frontend-network
  • backend-network
  • database-network
  • Isolation between layers
end note

@enduml