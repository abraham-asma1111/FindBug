@startuml Design_Domain_Code_Review

' ============================================
' Design Class Model - Domain Layer
' Module 7: Expert Code Review
' ============================================

skinparam classAttributeIconSize 0

class CodeReviewEngagement {
    - reviewId: UUID {PK, unique, not null}
    - organizationId: UUID {FK->Organization.organizationId, not null}
    - name: String {max=255, not null}
    - repositoryUrl: String {max=500, nullable}
    - codeScope: Text {max=2000, not null}
    - programmingLanguages: JSON {array of strings, not null}
    - reviewType: ReviewType {enum, not null}
    - status: ReviewStatus {enum, default=PENDING}
    - deadline: DateTime {nullable}
    - assignedReviewers: JSON {array of UUIDs}
    - totalFindings: Integer {default=0}
    - criticalFindings: Integer {default=0}
    - createdAt: DateTime {default=now()}
    - completedAt: DateTime {nullable}
    
    + create(data: CodeReviewDTO): CodeReviewEngagement throws ValidationException
    + assignReviewers(researcherIds: List<UUID>): void
    + start(): void
    + complete(): void
    + generateReport(): CodeReviewReportDTO
}

enum ReviewType {
    SECURITY_REVIEW
    QUALITY_REVIEW
    FULL_REVIEW
    COMPLIANCE_REVIEW
}

enum ReviewStatus {
    PENDING
    IN_PROGRESS
    COMPLETED
    CANCELLED
}

class CodeReviewFinding {
    - findingId: UUID {PK, unique, not null}
    - reviewId: UUID {FK->CodeReviewEngagement.reviewId, not null}
    - researcherId: UUID {FK->Researcher.researcherId, not null}
    - issueType: IssueType {enum, not null}
    - severity: SeverityLevel {enum, not null}
    - title: String {max=255, not null}
    - description: Text {max=5000, not null}
    - filePath: String {max=500, not null}
    - lineNumber: Integer {min=1, nullable}
    - codeSnippet: Text {max=2000, nullable}
    - recommendation: Text {max=2000, not null}
    - cweId: String {max=20, nullable}
    - status: FindingStatus {enum, default=OPEN}
    - createdAt: DateTime {default=now()}
    - resolvedAt: DateTime {nullable}
    
    + report(data: FindingDTO): CodeReviewFinding throws ValidationException
    + resolve(resolution: String): void
    + dismiss(reason: String): void
}

enum IssueType {
    SECURITY_VULNERABILITY
    CODE_SMELL
    BUG
    PERFORMANCE_ISSUE
    DEAD_CODE
    INSECURE_DEPENDENCY
    LOGIC_FLAW
    BEST_PRACTICE_VIOLATION
}

enum FindingStatus {
    OPEN
    ACKNOWLEDGED
    RESOLVED
    DISMISSED
    WONT_FIX
}

' Relationships
Organization "1" -- "0..*" CodeReviewEngagement : initiates
CodeReviewEngagement "1" -- "0..*" Researcher : assigns
CodeReviewEngagement "1" -- "0..*" CodeReviewFinding : produces

@enduml
