@startuml Design_Domain_SSDLC_Integration

' ============================================
' Design Class Model - Domain Layer
' Module 8: SSDLC Integration (Jira/GitHub)
' ============================================

skinparam classAttributeIconSize 0

class ExternalIntegration {
    - integrationId: UUID {PK, unique, not null}
    - organizationId: UUID {FK->Organization.organizationId, not null}
    - toolName: String {max=100, not null}
    - toolType: IntegrationType {enum, not null}
    - apiKey: String {max=500, encrypted, not null}
    - apiSecret: String {max=500, encrypted, nullable}
    - webhookUrl: String {max=500, nullable}
    - status: IntegrationStatus {enum, default=ACTIVE}
    - lastSyncAt: DateTime {nullable}
    - syncFrequency: Integer {minutes, default=15}
    - configuredAt: DateTime {default=now()}
    - configuredBy: UUID {FK->User.userId, not null}
    
    + configure(data: IntegrationDTO): ExternalIntegration throws ValidationException
    + sync(): SyncResult throws SyncException
    + testConnection(): Boolean
    + disable(): void
    + enable(): void
}

enum IntegrationType {
    JIRA
    GITHUB
    GITLAB
    AZURE_DEVOPS
}

enum IntegrationStatus {
    ACTIVE
    INACTIVE
    ERROR
    SYNCING
}

class JiraConnector {
    - connectorId: UUID {PK, FK->ExternalIntegration.integrationId}
    - jiraUrl: String {max=500, not null}
    - projectKey: String {max=50, not null}
    - issueTypeId: String {max=50, not null}
    - customFieldMappings: JSON {nullable}
    - priorityMapping: JSON {nullable}
    
    + syncIssues(): Integer throws JiraException
    + createIssue(report: VulnerabilityReport): String throws JiraException
    + updateIssue(issueKey: String, data: JSON): void
    + getIssue(issueKey: String): JiraIssueDTO
}

class GitHubConnector {
    - connectorId: UUID {PK, FK->ExternalIntegration.integrationId}
    - repoUrl: String {max=500, not null}
    - owner: String {max=100, not null}
    - repository: String {max=100, not null}
    - accessToken: String {max=500, encrypted, not null}
    - labelMappings: JSON {nullable}
    
    + syncIssues(): Integer throws GitHubException
    + createIssue(report: VulnerabilityReport): Integer throws GitHubException
    + updateIssue(issueNumber: Integer, data: JSON): void
    + getIssue(issueNumber: Integer): GitHubIssueDTO
    + addComment(issueNumber: Integer, comment: String): void
}

class SyncLog {
    - logId: UUID {PK, unique, not null}
    - integrationId: UUID {FK->ExternalIntegration.integrationId, not null}
    - syncDate: DateTime {default=now()}
    - status: SyncStatus {enum, not null}
    - recordsSynced: Integer {default=0}
    - recordsFailed: Integer {default=0}
    - errorMessage: Text {max=2000, nullable}
    - duration: Integer {milliseconds, default=0}
    - details: JSON {nullable}
    
    + record(result: SyncResult): void
    + getHistory(integrationId: UUID, limit: Integer): List<SyncLog>
}

enum SyncStatus {
    SUCCESS
    PARTIAL_SUCCESS
    FAILED
    RETRY
    CANCELLED
}

class IssueMapping {
    - mappingId: UUID {PK, unique, not null}
    - reportId: UUID {FK->VulnerabilityReport.reportId, unique, not null}
    - integrationId: UUID {FK->ExternalIntegration.integrationId, not null}
    - externalIssueId: String {max=255, not null}
    - externalIssueUrl: String {max=500, not null}
    - createdAt: DateTime {default=now()}
    - lastSyncedAt: DateTime {default=now()}
    - syncStatus: String {max=50, default='synced'}
    
    + create(reportId: UUID, externalId: String): IssueMapping
    + updateSyncStatus(status: String): void
}

' Relationships
ExternalIntegration <|-- JiraConnector
ExternalIntegration <|-- GitHubConnector
Organization "1" -- "0..*" ExternalIntegration : configures
ExternalIntegration "1" -- "0..*" SyncLog : logs
VulnerabilityReport "1" -- "0..1" IssueMapping : syncs

@enduml
