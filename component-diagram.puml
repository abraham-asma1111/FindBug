@startuml Component_Diagram

' ============================================
' COMPONENT DIAGRAM
' Bug Bounty and Its Simulation Platform
' Team: Niway Tadesse, Abraham Asimamaw, Melkamu Tesfa
' Advisor: Yosef Worku
' Internal Component Structure and Relationships
' ============================================

!define COMPONENT component

skinparam component {
    BackgroundColor<<UI>> LightBlue
    BackgroundColor<<Service>> LightGreen
    BackgroundColor<<Data>> LightCyan
    BackgroundColor<<Cache>> Orange
    BackgroundColor<<External>> Pink
    BackgroundColor<<Simulation>> LightYellow
}

title Bug Bounty and Its Simulation Platform - Component Diagram

' ============================================
' PRESENTATION LAYER (Next.js Frontend)
' ============================================

package "Presentation Layer (Next.js)" <<UI>> {
    component "Leaderboard Analytics\n(Dashboard UI)" as leaderboard_ui
    component "Simulation/Training Interface\n(Practice Mode)" <<Simulation>> as simulation_ui
    component "Researcher Portal\n(Reports, Programs)" as researcher_ui
    component "Organization Portal\n(Management)" as organization_ui
    component "Admin/Triage Portal\n(Validation)" as admin_ui
}

' ============================================
' MICROSERVICE LAYER (FastAPI Backend)
' ============================================

package "Microservice Layer (FastAPI)" <<Service>> {
    
    ' Core Business Services
    component "Bug Bounty Engine Service\n(Programs, Reports)" as bug_bounty_service
    component "PTaaS Engine Service\n(Penetration Testing)" as ptaas_service
    component "Researcher Matching Service\n(Skill Matching)" as matching_service
    component "AI Red Teaming Engine Service\n(AI Security Testing)" as ai_red_service
    
    ' Support Services
    component "Reward & Commission Service\n(Payment Processing)" as reward_service
    component "Notification Service\n(Email, SMS, Push)" as notification_service
    component "SSDLC Integration Service\n(Jira, GitHub)" as ssdlc_service
    
    ' Simulation Services (Isolated)
    component "Simulation/Challenge Engine Service\n(Practice Environment)" <<Simulation>> as simulation_service
}

' ============================================
' DATA LAYER
' ============================================

package "Data Layer" <<Data>> {
    component "PostgreSQL Database\n(Relational + JSONB)" as postgresql_db
}

' ============================================
' CACHE & ASYNC LAYER
' ============================================

package "Cache & Async Layer" <<Cache>> {
    component "Celery Workers\n(Background Tasks)" as celery_workers
    component "Redis Cache/Broker\n(Session, Queue)" as redis_cache
}

' ============================================
' EXTERNAL SERVICES
' ============================================

package "External Services" <<External>> {
    component "CI/CD Repository Integration\n(GitHub, GitLab)" as cicd_integration
    component "Payment Gateway\n(Telebirr, CBE Birr)" as payment_gateway
    component "Email/Messaging Service\n(SMTP, Twilio)" as messaging_service
}

' ============================================
' COMPONENT CONNECTIONS
' ============================================

' UI to Services Connections
leaderboard_ui --> bug_bounty_service
leaderboard_ui --> matching_service
simulation_ui --> simulation_service
researcher_ui --> bug_bounty_service
researcher_ui --> ptaas_service
researcher_ui --> simulation_service
organization_ui --> bug_bounty_service
organization_ui --> ptaas_service
organization_ui --> ai_red_service
admin_ui --> bug_bounty_service
admin_ui --> ptaas_service
admin_ui --> matching_service

' Inter-Service Connections
bug_bounty_service --> reward_service
bug_bounty_service --> notification_service
ptaas_service --> matching_service
ptaas_service --> notification_service
ai_red_service --> matching_service
ai_red_service --> notification_service
reward_service --> notification_service
ssdlc_service --> bug_bounty_service
ssdlc_service --> ptaas_service

' Services to Cache/Async
bug_bounty_service --> redis_cache
ptaas_service --> redis_cache
matching_service --> redis_cache
ai_red_service --> redis_cache
simulation_service --> redis_cache

notification_service --> celery_workers
reward_service --> celery_workers
ssdlc_service --> celery_workers
celery_workers --> redis_cache

' Services to Database
bug_bounty_service --> postgresql_db
ptaas_service --> postgresql_db
matching_service --> postgresql_db
ai_red_service --> postgresql_db
reward_service --> postgresql_db
simulation_service --> postgresql_db

' Services to External Systems
reward_service --> payment_gateway
notification_service --> messaging_service
ssdlc_service --> cicd_integration

' ============================================
' INTERFACES & PROTOCOLS
' ============================================

interface "REST API" as rest_api
interface "WebSocket" as websocket_api
interface "GraphQL" as graphql_api

' API Interfaces
leaderboard_ui ..> rest_api
simulation_ui ..> websocket_api
researcher_ui ..> rest_api
organization_ui ..> rest_api
admin_ui ..> rest_api

rest_api - bug_bounty_service
rest_api - ptaas_service
rest_api - matching_service
rest_api - ai_red_service
rest_api - reward_service
websocket_api - simulation_service
websocket_api - notification_service

' ============================================
' NOTES & ANNOTATIONS
' ============================================

note top of simulation_service
  **ISOLATED SIMULATION**
  • Separate database schema
  • No real payments
  • Practice vulnerabilities
  • OWASP Juice Shop integration
end note

note right of postgresql_db
  **Database Features**
  • JSONB for unstructured data
  • Full-text search
  • ACID transactions
  • Row-level security
end note

note right of redis_cache
  **Caching & Queuing**
  • Session storage
  • API response cache
  • Task queue (Celery)
  • Rate limiting
end note

note bottom of payment_gateway
  **Ethiopian Payment Systems**
  • Telebirr Mobile Money
  • CBE Birr Digital Wallet
  • Bank transfer APIs
end note

note bottom of cicd_integration
  **DevSecOps Integration**
  • Automated security scans
  • Vulnerability reporting
  • Code quality checks
end note

@enduml