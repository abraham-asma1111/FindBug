# ============================================================================
# SECURITY WARNING: This is a template file only!
# ============================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Change ALL passwords and secrets below
# 3. NEVER commit .env to Git (it's in .gitignore)
# 4. Use strong, unique passwords for production
# ============================================================================

# Database Configuration
# Generate strong password: openssl rand -base64 32
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@localhost:5432/bugbounty
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=bugbounty

# Redis Configuration
# Generate strong password: openssl rand -base64 32
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT Configuration
# CRITICAL: Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32_TO_GENERATE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO/S3 Configuration
# Generate: openssl rand -base64 20
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY_MIN_20_CHARS
MINIO_BUCKET_NAME=bugbounty-attachments
MINIO_USE_SSL=false

# Email Configuration (SMTP)
# Use app-specific password for Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=CHANGE_ME_APP_SPECIFIC_PASSWORD
SMTP_FROM=noreply@bugbounty.com

# Celery Configuration
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/2

# Application Configuration
APP_NAME=Bug Bounty Platform
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Payment Gateway Configuration (Ethiopian)
# Get from respective dashboards
CHAPA_SECRET_KEY=CHANGE_ME_GET_FROM_CHAPA_DASHBOARD
TELEBIRR_APP_ID=CHANGE_ME_GET_FROM_TELEBIRR
TELEBIRR_APP_KEY=CHANGE_ME_GET_FROM_TELEBIRR

# VRT Configuration
VRT_JSON_PATH=src/data/vrt.json

# Security Settings
RATE_LIMIT_PER_MINUTE=60
MAX_FILE_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================================================
# PRODUCTION CHECKLIST:
# ============================================================================
# [ ] All passwords changed from defaults
# [ ] JWT secret generated with openssl rand -hex 32
# [ ] Redis password set
# [ ] MinIO credentials changed
# [ ] Email credentials configured
# [ ] Payment gateway keys obtained
# [ ] DEBUG=False in production
# [ ] ENVIRONMENT=production
# [ ] SSL/TLS enabled (MINIO_USE_SSL=true)
# [ ] Strong CORS origins configured
# [ ] Rate limiting configured appropriately
# ============================================================================


# Persona KYC Configuration
PERSONA_API_KEY=your_persona_api_key_here
PERSONA_TEMPLATE_ID=itmpl_your_template_id_here
PERSONA_WEBHOOK_SECRET=your_webhook_secret_here
