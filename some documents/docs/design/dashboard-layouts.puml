@startuml Dashboard_Layouts

title Dashboard Layouts - 4 Portal Architecture

skinparam componentStyle rectangle

' Researcher Dashboard
package "Researcher Dashboard (platform.com/researcher)" {
    rectangle "Header" as RHeader {
        [Logo]
        [Navigation: Programs | Reports | Earnings | Profile]
        [Go to Learning →]
        [Notifications]
        [User Menu]
    }
    
    rectangle "Main Content" as RContent {
        rectangle "Stats Cards" {
            [Total Earnings]
            [Active Reports]
            [Reputation Score]
            [Rank]
        }
        
        rectangle "Quick Actions" {
            [Browse Programs]
            [Submit Report]
            [Practice in Dojo]
        }
        
        rectangle "Recent Activity" {
            [Latest Reports]
            [Recent Rewards]
            [Notifications]
        }
        
        rectangle "Leaderboard" {
            [Top Researchers]
            [Your Position]
        }
    }
    
    rectangle "Footer" as RFooter {
        [Help]
        [Docs]
        [Contact]
    }
}

' Organization Dashboard
package "Organization Dashboard (platform.com/organization)" {
    rectangle "Header" as OHeader {
        [Logo]
        [Navigation: Programs | Reports | Team | Analytics]
        [Notifications]
        [User Menu]
    }
    
    rectangle "Main Content" as OContent {
        rectangle "Stats Cards" {
            [Active Programs]
            [Pending Reports]
            [Total Paid]
            [Researchers]
        }
        
        rectangle "Quick Actions" {
            [Create Program]
            [Review Reports]
            [Invite Team]
        }
        
        rectangle "Program Overview" {
            [Program List]
            [Status]
            [Budget]
        }
        
        rectangle "Recent Reports" {
            [Pending Triage]
            [Awaiting Review]
            [Resolved]
        }
    }
    
    rectangle "Footer" as OFooter {
        [Help]
        [Docs]
        [Contact]
    }
}

' Admin Dashboard
package "Admin Dashboard (platform.com/admin)" {
    rectangle "Header" as AHeader {
        [Logo]
        [Navigation: Users | Staff | Programs | System | Audit]
        [Notifications]
        [User Menu]
    }
    
    rectangle "Main Content" as AContent {
        rectangle "Stats Cards" {
            [Total Users]
            [Active Programs]
            [Pending Reports]
            [System Health]
        }
        
        rectangle "Quick Actions" {
            [Add Staff]
            [Moderate Program]
            [View Audit Logs]
        }
        
        rectangle "System Overview" {
            [User Growth]
            [Platform Activity]
            [Revenue]
        }
        
        rectangle "Recent Activity" {
            [New Users]
            [Staff Actions]
            [System Events]
        }
    }
    
    rectangle "Footer" as AFooter {
        [System Status]
        [Version]
    }
}

' Learning Dashboard
package "Learning Dashboard (learn.platform.com)" {
    rectangle "Header" as LHeader {
        [Logo]
        [Navigation: Challenges | Progress | Leaderboard | Resources]
        [← Back to Main]
        [Notifications]
        [User Menu]
    }
    
    rectangle "Main Content" as LContent {
        rectangle "Stats Cards" {
            [Challenges Completed]
            [Total Points]
            [Current Level]
            [Badges Earned]
        }
        
        rectangle "Quick Actions" {
            [Start Challenge]
            [Continue Learning Path]
            [View Achievements]
        }
        
        rectangle "Challenge Grid" {
            [Web Security]
            [API Security]
            [Mobile Security]
            [Network Security]
        }
        
        rectangle "Progress Tracker" {
            [Learning Path]
            [Completed]
            [In Progress]
            [Locked]
        }
    }
    
    rectangle "Footer" as LFooter {
        [Tutorials]
        [Community]
        [Help]
    }
}

note right of RHeader
  Researcher Portal Features:
  - Bug bounty focused
  - Earnings tracking
  - Reputation system
  - Direct link to learning
end note

note right of OHeader
  Organization Portal Features:
  - Program management
  - Report review
  - Team collaboration
  - Analytics dashboard
end note

note right of AHeader
  Admin Portal Features:
  - Full system control
  - User management
  - Staff provisioning
  - Audit logging
end note

note right of LHeader
  Learning Portal Features:
  - Separate branding
  - Gamification focus
  - Challenge-based
  - SSO from main platform
  - Skills sync back
end note

@enduml
