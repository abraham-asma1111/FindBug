@startuml Dispute_Resolution

' ============================================
' ACTIVITY DIAGRAM: Dispute Resolution Process
' Bug Bounty and Its Simulation Platform
' ============================================

title Dispute Resolution - Activity Diagram

|Organization|
start
:Review Triaged Report;
:Disagree with Assessment;
:Click "Dispute Report";
:Provide Dispute Reason;
:Submit Dispute;

|System|
:Create Dispute Record;
:Update Report Status = "Disputed";
:Notify Stakeholders;

fork
  |Researcher|
  :Receive Dispute Notification;
  :Review Dispute Reason;
fork again
  |Triage Analyst|
  :Receive Dispute Notification;
  :Review Original Assessment;
fork again
  |Admin|
  :Receive Escalation Alert;
end fork

partition "Evidence Collection" {
  |Researcher|
  :Prepare Response;
:Gather Additional Evidence;
:Provide Technical Details;
:Submit Response;

|System|
:Store Response;
:Notify Organization;

|Organization|
:Review Researcher Response;
:Provide Counter-Arguments;
:Submit Additional Comments;

|System|
:Store All Evidence;
:Compile Dispute Case;
}

partition "Mediation" {
  |Triage Analyst|
  :Review Complete Case;
:Analyze Both Sides;
:Re-evaluate Vulnerability;
:Test Reproduction Steps;

if (Clear Resolution?) then (yes)
  :Make Decision;
  :Provide Detailed Reasoning;
  :Update Report Status;
  
  if (Decision?) then (Favor Researcher)
    :Restore Original Assessment;
    :Set Reward Amount;
    
    |System|
    :Update Report = "Validated";
    :Notify Parties;
    
    |Researcher|
    :Receive Validation;
    :Accept Reward;
    stop
    
  else (Favor Organization)
    :Adjust Assessment;
    :Reduce/Remove Reward;
    
    |System|
    :Update Report Status;
    :Notify Parties;
    
    |Researcher|
    :Receive Decision;
    
    if (Accept Decision?) then (yes)
      :Close Case;
      stop
    else (no)
      :Escalate to Admin;
      |Admin|
    endif
  endif
  
else (no - Complex Case)
  :Escalate to Admin;
  
  |Admin|
  :Review Escalated Case;
  :Consult Security Experts;
  :Request External Opinion;
  
  if (Need More Info?) then (yes)
    :Request Clarification;
    
    fork
      |Researcher|
      :Provide Clarification;
    fork again
      |Organization|
      :Provide Clarification;
    end fork
    
    |Admin|
    :Review New Information;
  endif
  
  :Make Final Decision;
  :Document Reasoning;
  :Update Report;
  
  |System|
  :Apply Final Decision;
  :Close Dispute;
  :Notify All Parties;
  
  fork
    |Researcher|
    :Receive Final Decision;
  fork again
    |Organization|
    :Receive Final Decision;
  end fork
  
  :Log Dispute Resolution;
  :Update Dispute Statistics;
  
  stop
endif
}

@enduml