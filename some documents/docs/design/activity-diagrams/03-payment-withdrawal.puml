@startuml Payment_Withdrawal

' ============================================
' ACTIVITY DIAGRAM: Payment and Withdrawal
' Bug Bounty and Its Simulation Platform
' ============================================

title Payment Processing and Withdrawal - Activity Diagram

|Finance Officer|
start
:Login to Finance Portal;
:View Pending Payments;
:Review Validated Reports;

if (Reports Ready for Payment?) then (yes)
  :Select Reports for Batch;
  :Verify Total Amount;
  :Approve Batch Payment;
else (no)
  :Wait for Validations;
  stop
endif

|System|
:Process Batch Payment;

fork
  :Update Report Status;
fork again
  :Credit Researcher Wallets;
fork again
  :Create Transaction Records;
fork again
  :Send Payment Notifications;
end fork

:Log Payment Activity;

|Researcher|
:Receive Payment Email;
:Login to Portal;
:Check Wallet Balance;

if (Want to Withdraw?) then (yes)
  :Navigate to Wallet;
  :Click "Withdraw Funds";
  :Enter Withdrawal Amount;
  :Select Payment Method\n(Telebirr/CBE Birr/Bank);
  
  if (Amount <= Balance?) then (yes)
    if (Amount >= Minimum?) then (yes)
      :Provide Payment Details\n(Phone/Account Number);
      :Confirm Withdrawal;
    else (no)
      :Show Minimum Amount Error;
      stop
    endif
  else (no)
    :Show Insufficient Balance;
    stop
  endif
else (no)
  :Keep Balance for Future;
  stop
endif

|System|
:Validate Withdrawal Request;
:Deduct from Wallet;
:Create Withdrawal Record;
:Queue Payment Task;

|Celery Worker|
:Pick Withdrawal Task;
:Call Payment Gateway API;

|Payment Gateway|
:Process Transfer;

if (Transfer Successful?) then (yes)
  :Return Success Response;
  
  |Celery Worker|
  :Update Status = "Completed";
  :Send Success Notification;
  
  |Researcher|
  :Receive SMS Confirmation;
  :Check Bank/Mobile Money;
  :Funds Received;
  stop
  
else (no)
  :Return Failure Response;
  
  |Celery Worker|
  :Update Status = "Failed";
  :Refund Wallet Balance;
  :Send Failure Notification;
  
  |Researcher|
  :Receive Failure Email;
  
  if (Retry?) then (yes)
    :Check Payment Details;
    :Resubmit Withdrawal;
    |System|
  else (no)
    :Contact Support;
    stop
  endif
endif

@enduml