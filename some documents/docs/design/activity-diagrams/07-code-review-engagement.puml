@startuml Code_Review_Engagement

' ============================================
' ACTIVITY DIAGRAM: Expert Code Review
' Bug Bounty and Its Simulation Platform
' ============================================

title Expert Code Review Engagement - Activity Diagram

|Organization|
start
:Login to Platform;
:Navigate to Code Review;
:Click "Request Code Review";

:Select Review Type\n(Full Audit, Specific Module, Pre-Release);
:Upload Source Code\n(ZIP or Git Repository);
:Specify Technology Stack;
:Define Review Scope;
:Set Deadline;
:Set Budget;
:Submit Request;

|System|
:Validate Request;
:Upload Code to MinIO;
:Create Engagement Record;
:Analyze Code Complexity;
:Estimate Review Time;

:Match Expert Reviewers;
note right
  Based on:
  - Technology expertise
  - Availability
  - Past performance
end note

:Send Invitations to Experts;

|Expert Reviewer|
:Receive Invitation;
:Review Engagement Details;
:Check Code Scope;

if (Accept Engagement?) then (yes)
  :Accept Invitation;
  
  |System|
  :Assign Reviewer;
  :Grant Code Access;
  :Start Engagement;
  
  |Expert Reviewer|
  :Download Source Code;
  :Setup Review Environment;
  :Start Code Analysis;
  
  repeat
    :Review Code Section;
    :Identify Issues;
    
    if (Issue Found?) then (yes)
      :Document Finding\n(Type, Severity, Location);
      :Provide Fix Recommendation;
      :Add Code Snippet;
      :Submit Finding;
      
      |System|
      :Store Finding;
      :Notify Organization;
    endif
    
  repeat while (More Code to Review?) is (yes)
  ->no;
  
  :Compile All Findings;
  :Write Executive Summary;
  :Provide Recommendations;
  :Generate Review Report;
  :Submit Final Report;
  
  |System|
  :Upload Report to MinIO;
  :Mark Engagement Complete;
  :Calculate Payment;
  :Notify Organization;
  
  |Organization|
  :Receive Completion Email;
  :Download Report;
  :Review Findings;
  
  if (Satisfied with Review?) then (yes)
    :Approve Payment;
    
    |System|
    :Process Payment;
    :Credit Reviewer Wallet;
    
    |Expert Reviewer|
    :Receive Payment;
    stop
    
  else (no - Request Clarification)
    :Submit Questions;
    
    |Expert Reviewer|
    :Provide Clarifications;
    |Organization|
    :Review Clarifications;
    
    if (Now Satisfied?) then (yes)
      :Approve Payment;
      |System|
      :Process Payment;
      stop
    else (no)
      :Escalate to Admin;
      stop
    endif
  endif
  
else (no - Decline)
  :Decline Invitation;
  
  |System|
  :Find Alternative Reviewer;
  :Send New Invitations;
  stop
endif

@enduml