@startuml SSDLC_Integration

' ============================================
' ACTIVITY DIAGRAM: SSDLC Tool Integration
' Bug Bounty and Its Simulation Platform
' ============================================

title SSDLC Integration (Jira/GitHub) - Activity Diagram

|Organization|
start
:Login to Platform;
:Navigate to Integrations;
:Select Integration Type\n(Jira or GitHub);

if (Integration Type?) then (Jira)
  :Enter Jira Details\n(URL, Project Key, API Token);
  :Configure Field Mapping;
  :Set Sync Rules;
else (GitHub)
  :Authorize GitHub OAuth;
  :Select Repository;
  :Configure Issue Labels;
  :Set Sync Rules;
endif

:Test Connection;

|System|
:Validate Credentials;
:Test API Connection;

if (Connection Successful?) then (yes)
  :Save Integration Config;
  :Enable Auto-Sync;
  :Create Webhook;
else (no)
  :Show Connection Error;
  |Organization|
  :Fix Configuration;
  stop
endif

|Organization|
:Enable Auto-Sync for Program;

note right
  Sync Options:
  - Create issues automatically
  - Update on status change
  - Sync comments
  - Attach evidence
end note

partition "Vulnerability Report Sync" {
  |Researcher|
  :Submit Vulnerability Report;

|System|
:Validate Report;
:Store in Database;

if (Auto-Sync Enabled?) then (yes)
  :Queue Sync Task;
  
  |Celery Worker|
  :Pick Sync Task;
  :Prepare Issue Data;
  
  if (Integration Type?) then (Jira)
    :Create Jira Issue;
    :POST /rest/api/3/issue;
    
    |Jira|
    :Create Issue;
    :Return Issue Key;
    
    |Celery Worker|
    :Store Issue Key;
    :Attach Evidence Files;
    :Add Comments;
    
  else (GitHub)
    :Create GitHub Issue;
    :POST /repos/{owner}/{repo}/issues;
    
    |GitHub|
    :Create Issue;
    :Return Issue Number;
    
    |Celery Worker|
    :Store Issue Number;
    :Add Labels;
    :Upload Evidence to Release;
  endif
  
  :Update Sync Status;
  :Log Sync Activity;
  
  |System|
  :Send Sync Confirmation;
  
  |Organization|
  :Receive Notification;
  :View Issue in Jira/GitHub;
  
else (no)
  :Manual Sync Available;
  stop
endif
}

partition "Status Update Sync" {
  |Organization|
  :Update Issue Status in Jira/GitHub;

|Jira/GitHub|
:Trigger Webhook;
:POST /webhook/ssdlc;

|System|
:Receive Webhook;
:Validate Signature;
:Parse Payload;

if (Valid Webhook?) then (yes)
  :Extract Status Change;
  :Find Linked Report;
  
  if (Report Found?) then (yes)
    :Update Report Status;
    :Log Status Change;
    :Notify Researcher;
    
    |Researcher|
    :Receive Status Update;
    stop
    
  else (no)
    :Log Unmatched Webhook;
    stop
  endif
  
else (no)
  :Reject Webhook;
  :Log Security Event;
  stop
endif
}

partition "Manual Sync" {
  |Organization|
  :View Report Details;
  :Click "Sync to Jira/GitHub";

|System|
:Check Integration Status;

if (Integration Active?) then (yes)
  :Queue Manual Sync;
  
  |Celery Worker|
  :Create/Update Issue;
  :Sync Comments;
  :Update Status;
  
  |System|
  :Show Sync Success;
  
  |Organization|
  :View Synced Issue;
  stop
  
else (no)
  :Show "Integration Not Configured";
  |Organization|
  :Configure Integration;
  stop
endif
}

@enduml