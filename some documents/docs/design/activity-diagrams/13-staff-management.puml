@startuml Staff_Management_Activity

title Staff Account Management Activity Diagram (Simplified)

start

:Super Admin Accesses Admin Panel;

:Navigate to Staff Management;

:Click "Add New Staff";

:Fill Staff Details\n(Email, Name, Role, Permissions);

:Submit Form;

if (Valid Data?) then (no)
    :Show Error;
    stop
else (yes)
    :Create User Record\n(is_staff=true, status=PENDING);
    
    :Generate Invitation Token\n(expires in 48 hours);
    
    :Send Welcome Email\nwith Invitation Link;
    
    :Log Staff Creation Event;
endif

:Staff Receives Email;

:Click Invitation Link;

if (Token Valid?) then (no)
    :Show Error: Invalid/Expired Link;
    stop
else (yes)
    :Display Password Setup Page;
endif

:Staff Enters New Password;

if (Password Strong Enough?) then (no)
    :Show Error: Weak Password;
    stop
else (yes)
    :Hash Password (bcrypt);
    
    :Update User Status to ACTIVE;
    
    :Delete Invitation Token;
    
    :Generate JWT Token;
    
    :Redirect to Dashboard;
endif

if (Staff Role?) then (SUPER_ADMIN)
    :Access Full Admin Panel;
elseif (ADMIN) then
    :Access Admin Panel;
elseif (TRIAGE_SPECIALIST) then
    :Access Triage Dashboard;
elseif (FINANCIAL_OFFICER) then
    :Access Finance Dashboard;
else (SUPPORT_STAFF)
    :Access Support Dashboard;
endif

:Perform Daily Tasks;

floating note right
    Staff Management Actions:
    - Update Permissions
    - Suspend Account
    - Reactivate Account
    - Remove Staff
end note

stop

@enduml
