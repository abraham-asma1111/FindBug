@startuml Researcher_Use_Cases

title Researcher Use Cases - Bug Bounty Platform

actor "Researcher" as Researcher
actor "Payment Gateway" as PaymentGW
actor "Email Service" as EmailService

rectangle "Bug Bounty Platform" {
    
    ' Authentication & Profile
    usecase "Register Account" as UC1
    usecase "Login" as UC2
    usecase "Complete KYC Verification" as UC3
    usecase "Update Profile" as UC4
    usecase "Enable Two-Factor Auth" as UC5
    
    ' Bug Bounty Activities
    usecase "Browse Programs" as UC6
    usecase "View Program Details" as UC7
    usecase "Submit Vulnerability Report" as UC8
    usecase "Upload Proof of Concept" as UC9
    usecase "Track Report Status" as UC10
    usecase "Respond to Triage Questions" as UC11
    usecase "View Report History" as UC12
    
    ' Rewards & Payments
    usecase "View Earnings Dashboard" as UC13
    usecase "Check Balance" as UC14
    usecase "Request Withdrawal" as UC15
    usecase "Add Payment Method" as UC16
    usecase "View Transaction History" as UC17
    
    ' Engagement
    usecase "Participate in Live Events" as UC18
    usecase "Join PTaaS Engagement" as UC19
    usecase "Collaborate with Team" as UC20
    
    ' Communication
    usecase "Send Messages" as UC21
    usecase "Receive Notifications" as UC22
    usecase "View Announcements" as UC23
    
    ' Reputation & Ranking
    usecase "View Reputation Score" as UC24
    usecase "View Leaderboard" as UC25
    usecase "Earn Badges" as UC26
}

' Relationships
Researcher --> UC1
Researcher --> UC2
Researcher --> UC3
Researcher --> UC4
Researcher --> UC5
Researcher --> UC6
Researcher --> UC7
Researcher --> UC8
