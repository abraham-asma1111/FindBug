@startuml Learning_Platform_Use_Cases

title Learning Platform Use Cases

actor "Learner\n(Any User)" as Learner
actor "Instructor\n(Admin)" as Instructor

rectangle "Learning Platform (Simulation Environment)" {
    
    ' Access & Authentication
    package "Access" {
        usecase "Login to Learning Platform" as UC1
        usecase "SSO from Main Platform" as UC2
        usecase "View Learning Dashboard" as UC3
    }
    
    ' Learning Paths
    package "Learning Paths" {
        usecase "Browse Learning Paths" as UC4
        usecase "Enroll in Course" as UC5
        usecase "Track Progress" as UC6
        usecase "View Completed Courses" as UC7
    }
    
    ' Simulations & Challenges
    package "Practice" {
        usecase "Access Simulation Environment" as UC8
        usecase "Start Challenge" as UC9
        usecase "Practice Vulnerability Discovery" as UC10
        usecase "Submit Solution" as UC11
        usecase "View Hints" as UC12
        usecase "Reset Challenge" as UC13
        usecase "View Solution" as UC14
    }
    
    ' Challenge Types
    package "Challenge Categories" {
        usecase "Web Application Security" as UC15
        usecase "API Security" as UC16
        usecase "Mobile Security" as UC17
        usecase "Network Security" as UC18
        usecase "Cloud Security" as UC19
        usecase "Cryptography" as UC20
    }
    
    ' Achievements & Gamification
    package "Achievements" {
        usecase "Earn Badges" as UC21
        usecase "Unlock Achievements" as UC22
        usecase "View Leaderboard" as UC23
        usecase "Earn Points" as UC24
        usecase "Level Up" as UC25
    }
    
    ' Resources
    package "Learning Resources" {
        usecase "Access Tutorials" as UC26
        usecase "Watch Video Lessons" as UC27
        usecase "Read Documentation" as UC28
        usecase "Download Resources" as UC29
        usecase "Access Cheat Sheets" as UC30
    }
    
    ' Community
    package "Community" {
        usecase "Join Discussion Forums" as UC31
        usecase "Ask Questions" as UC32
        usecase "Share Solutions" as UC33
        usecase "Rate Challenges" as UC34
    }
    
    ' Instructor Features
    package "Content Management" {
        usecase "Create Challenges" as UC35
        usecase "Update Content" as UC36
        usecase "Review Submissions" as UC37
        usecase "Manage Learning Paths" as UC38
        usecase "View Analytics" as UC39
    }
}

