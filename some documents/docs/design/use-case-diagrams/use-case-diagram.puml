@startuml Use_Case_Diagram

title Bug Bounty and Its Simulation Platform - Use Case Diagram

left to right direction
skinparam packageStyle rectangle

' Actors
actor "Researcher" as Researcher
actor "Organization" as Organization
actor "Triage Specialist" as Triage
actor "Financial Officer" as Finance
actor "Administrator" as Admin
actor "Learner" as Learner

' System boundary
rectangle "Bug Bounty Platform" {
    
    ' Researcher Use Cases
    package "Researcher Features" {
        usecase "Register Account" as UC1
        usecase "Complete KYC" as UC2
        usecase "Browse Programs" as UC3
        usecase "Submit Vulnerability Report" as UC4
        usecase "Track Report Status" as UC5
        usecase "Receive Rewards" as UC6
        usecase "Withdraw Funds" as UC7
        usecase "View Dashboard" as UC8
        usecase "Participate in Live Events" as UC9
        usecase "Join PTaaS Engagement" as UC10
    }
    
    ' Organization Use Cases
    package "Organization Features" {
        usecase "Create Bounty Program" as UC11
        usecase "Manage Program Settings" as UC12
        usecase "Review Reports" as UC13
        usecase "Approve Rewards" as UC14
        usecase "Invite Team Members" as UC15
        usecase "View Analytics" as UC16
        usecase "Request PTaaS" as UC17
        usecase "Request Code Review" as UC18
        usecase "Integrate SSDLC Tools" as UC19
        usecase "Host Live Hacking Event" as UC20
    }
    
    ' Triage Use Cases
    package "Triage Features" {
        usecase "Validate Reports" as UC21
        usecase "Assign Severity" as UC22
        usecase "Detect Duplicates" as UC23
        usecase "Request Additional Info" as UC24
        usecase "Escalate to Organization" as UC25
    }
    
    ' Finance Use Cases
    package "Finance Features" {
        usecase "Approve Payments" as UC26
        usecase "Process Payouts" as UC27
        usecase "Generate Financial Reports" as UC28
        usecase "Manage Payment Methods" as UC29
    }
    
    ' Admin Use Cases
    package "Admin Features" {
        usecase "Manage Users" as UC30
        usecase "Provision Staff Accounts" as UC31
        usecase "Moderate Programs" as UC32
        usecase "Configure System" as UC33
        usecase "View Audit Logs" as UC34
        usecase "Resolve Disputes" as UC35
        usecase "Manage Permissions" as UC36
    }
    
    ' Learning Platform Use Cases
    package "Learning Platform" {
        usecase "Access Learning Portal" as UC37
        usecase "Practice Simulations" as UC38
        usecase "Complete Challenges" as UC39
        usecase "Earn Badges" as UC40
        usecase "View Progress" as UC41
        usecase "Access Tutorials" as UC42
    }
    
    ' Shared Use Cases
    package "Common Features" {
        usecase "Login/Logout" as UC43
        usecase "Update Profile" as UC44
        usecase "Enable MFA" as UC45
        usecase "View Notifications" as UC46
        usecase "Send Messages" as UC47
    }
}

' External Systems
actor "Payment Gateway\n(Chapa/Telebirr)" as PaymentGW
actor "Email Service" as EmailService
actor "SMS Service" as SMSService

' Researcher Relationships
Researcher --> UC1
Researcher --> UC2
Researcher --> UC3
Researcher --> UC4
Researcher --> UC5
Researcher --> UC6
Researcher --> UC7
Researcher --> UC8
Researcher --> UC9
Researcher --> UC10
Researcher --> UC43
Researcher --> UC44
Researcher --> UC45
Researcher --> UC46
Researcher --> UC47

' Organization Relationships
Organization --> UC11
Organization --> UC12
Organization --> UC13
Organization --> UC14
Organization --> UC15
Organization --> UC16
Organization --> UC17
Organization --> UC18
Organization --> UC19
Organization --> UC20
Organization --> UC43
Organization --> UC44
Organization --> UC45
Organization --> UC46
Organization --> UC47

' Triage Specialist Relationships
Triage --> UC21
Triage --> UC22
Triage --> UC23
Triage --> UC24
Triage --> UC25
Triage --> UC43
Triage --> UC44
Triage --> UC46

' Financial Officer Relationships
Finance --> UC26
Finance --> UC27
Finance --> UC28
Finance --> UC29
Finance --> UC43
Finance --> UC44
Finance --> UC46

' Administrator Relationships
Admin --> UC30
Admin --> UC31
Admin --> UC32
Admin --> UC33
Admin --> UC34
Admin --> UC35
Admin --> UC36
Admin --> UC43
Admin --> UC44
Admin --> UC46

' Learner Relationships (can be any user)
Learner --> UC37
Learner --> UC38
Learner --> UC39
Learner --> UC40
Learner --> UC41
Learner --> UC42

' Include/Extend Relationships
UC1 ..> UC43 : <<include>>
UC4 ..> UC3 : <<include>>
UC6 ..> UC5 : <<include>>
UC14 ..> UC13 : <<include>>
UC27 ..> UC26 : <<include>>
UC31 ..> UC30 : <<include>>

UC2 ..> UC1 : <<extend>>
UC45 ..> UC43 : <<extend>>
UC9 ..> UC3 : <<extend>>
UC10 ..> UC3 : <<extend>>

' External System Relationships
UC7 --> PaymentGW : uses
UC27 --> PaymentGW : uses
UC1 --> EmailService : sends verification
UC31 --> EmailService : sends invitation
UC46 --> EmailService : sends alerts
UC45 --> SMSService : sends OTP

note right of Researcher
  Primary user who finds
  and reports vulnerabilities
end note

note right of Organization
  Company that creates
  bug bounty programs
end note

note right of Triage
  Platform staff who
  validates reports
end note

note right of Finance
  Platform staff who
  manages payments
end note

note right of Admin
  Platform staff with
  full system access
end note

note right of Learner
  Any user accessing
  the learning platform
  (SSO from main platform)
end note

@enduml
