@startuml Staff_Use_Cases

title Platform Staff Use Cases

' Actors
actor "Administrator" as Admin
actor "Triage Specialist" as Triage
actor "Financial Officer" as Finance
actor "Support Staff" as Support

rectangle "Bug Bounty Platform - Staff Portal" {
    
    ' Admin Use Cases
    package "Administrator" {
        usecase "Provision Staff Accounts" as UC1
        usecase "Manage User Accounts" as UC2
        usecase "Suspend/Ban Users" as UC3
        usecase "Moderate Programs" as UC4
        usecase "Configure System Settings" as UC5
        usecase "Manage Permissions" as UC6
        usecase "View Audit Logs" as UC7
        usecase "Resolve Disputes" as UC8
        usecase "Generate System Reports" as UC9
        usecase "Manage Platform Content" as UC10
    }
    
    ' Triage Use Cases
    package "Triage Specialist" {
        usecase "View Pending Reports" as UC11
        usecase "Validate Vulnerability" as UC12
        usecase "Assign Severity Level" as UC13
        usecase "Detect Duplicate Reports" as UC14
        usecase "Request Additional Info" as UC15
        usecase "Escalate to Organization" as UC16
        usecase "Add Triage Comments" as UC17
        usecase "Mark as Invalid" as UC18
        usecase "View Triage Queue" as UC19
    }
    
    ' Finance Use Cases
    package "Financial Officer" {
        usecase "Review Payment Requests" as UC20
        usecase "Approve Payments" as UC21
        usecase "Reject Payments" as UC22
        usecase "Process Payouts" as UC23
        usecase "Verify KYC Documents" as UC24
        usecase "Generate Financial Reports" as UC25
        usecase "Manage Payment Methods" as UC26
        usecase "Handle Payment Disputes" as UC27
        usecase "View Budget Overview" as UC28
    }
    
    ' Support Use Cases
    package "Support Staff" {
        usecase "View Support Tickets" as UC29
        usecase "Respond to Inquiries" as UC30
        usecase "Assist with Onboarding" as UC31
        usecase "Troubleshoot Issues" as UC32
        usecase "Update Documentation" as UC33
        usecase "Escalate Complex Issues" as UC34
        usecase "Send Announcements" as UC35
    }
    
    ' Shared Staff Use Cases
    package "Common Staff Features" {
        usecase "Login with Staff Credentials" as UC36
        usecase "Enable MFA" as UC37
        usecase "View Staff Dashboard" as UC38
        usecase "Access Audit Trail" as UC39
        usecase "Send Internal Messages" as UC40
    }
}

