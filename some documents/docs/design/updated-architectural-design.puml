@startuml Updated_Architectural_Design

' ============================================
' UPDATED ARCHITECTURAL DESIGN
' Bug Bounty and Its Simulation Platform
' Team: Niway Tadesse, Abraham Asimamaw, Melkamu Tesfa
' Advisor: Yosef Worku
' Vertical Layout for Better Readability
' ============================================

!define RECTANGLE class

skinparam rectangle {
    BackgroundColor<<UI>> LightBlue
    BackgroundColor<<App>> LightGreen
    BackgroundColor<<Cache>> Orange
    BackgroundColor<<Queue>> Yellow
    BackgroundColor<<Storage>> LightGray
    BackgroundColor<<DB>> LightCyan
    BackgroundColor<<External>> Pink
    BackgroundColor<<Simulation>> LightYellow
}

skinparam direction top to bottom

title Bug Bounty and Its Simulation Platform - Updated Architecture

' ============================================
' LAYER 1: LOAD BALANCER & PROXY
' ============================================

rectangle "Load Balancer & Proxy Layer" {
    rectangle "Nginx\n(Reverse Proxy\nSSL Termination)" as nginx
}

' ============================================
' LAYER 2: PRESENTATION LAYER (UI)
' ============================================

rectangle "Presentation Layer (UI)" <<UI>> {
    rectangle "Researcher Portal" as researcher_ui
    rectangle "Organization Portal" as org_ui
    rectangle "Admin/Triage Portal" as admin_ui
    rectangle "Finance Officer Portal" as finance_ui
    rectangle "Simulation Interface" <<Simulation>> as sim_ui
}

' ============================================
' LAYER 3: CACHING LAYER
' ============================================

rectangle "Caching Layer" <<Cache>> {
    rectangle "Redis Cache\n(Application Data)" as redis_cache
    rectangle "Redis Sessions\n(JWT Storage)" as redis_session
    rectangle "Varnish Cache\n(HTTP Cache)" as varnish
}

' ============================================
' LAYER 4: APPLICATION LAYER - PRODUCTION SYSTEM
' ============================================

rectangle "Production System (Business Logic)" <<App>> {
    rectangle "Bug Bounty Engine" as bug_bounty
    rectangle "PTaaS Engine" as ptaas
    rectangle "AI Red Teaming Engine" as ai_red
    rectangle "Code Review Engine" as code_review
    rectangle "Live Hacking Engine" as live_hack
    rectangle "BountyMatch Engine" as bounty_match
}

' ============================================
' LAYER 5: APPLICATION LAYER - SIMULATION SYSTEM (ISOLATED)
' ============================================

rectangle "Simulation System (ISOLATED)" <<Simulation>> {
    rectangle "Simulation Engine" as simulation
    rectangle "Vulnerable Apps\n(OWASP Juice Shop)" as vuln_apps
    rectangle "Feedback & Scoring Engine" as feedback
}

' ============================================
' LAYER 6: OPERATIONAL SERVICES
' ============================================

rectangle "Operational Services Layer" <<App>> {
    rectangle "Report Management\n(Triage, Validation)" as report_mgmt
    rectangle "Severity & Scoring\n(VRT, CVSS)" as severity
    rectangle "Wallet/Payment Service" as wallet
    rectangle "Notification Engine" as notification
    rectangle "Analytics Engine" as analytics
    rectangle "Audit & Compliance" as audit
}

' ============================================
' LAYER 7: ASYNC PROCESSING
' ============================================

rectangle "Async Processing Layer" <<Queue>> {
    rectangle "Celery Workers\n(Background Tasks)" as celery_worker
    rectangle "Redis Message Broker\n(Task Queue)" as redis_broker
}

' ============================================
' LAYER 8: INTEGRATION & STORAGE
' ============================================

rectangle "Integration & Storage Layer" {
    rectangle "External Services" <<External>> {
        rectangle "Payment Gateways\n(Telebirr, CBE Birr)" as payment_gw
        rectangle "Email/SMS Service" as messaging
        rectangle "External APIs\n(Jira, GitHub)" as external_apis
    }
    
    rectangle "File Storage" <<Storage>> {
        rectangle "MinIO (Local)\nS3-Compatible" as minio
        rectangle "AWS S3 (Production)" as s3
    }
}

' ============================================
' LAYER 9: DATA LAYER
' ============================================

rectangle "Data Layer" <<DB>> {
    rectangle "Production Databases (PostgreSQL)" {
        rectangle "User Management DB" as user_db
        rectangle "Program & Engagement DB" as program_db
        rectangle "Reports & Evidence DB" as reports_db
        rectangle "Payments & Wallet DB" as payments_db
        rectangle "Analytics & Logs DB" as analytics_db
    }
    
    rectangle "Simulation Database (ISOLATED)" <<Simulation>> {
        rectangle "Simulation/Challenge DB\n(Practice Data Only)" as sim_db
    }
}

' ============================================
' CONNECTIONS (Vertical Flow)
' ============================================

' Layer 1 to Layer 2: Load Balancer to UI
nginx --> researcher_ui
nginx --> org_ui
nginx --> admin_ui
nginx --> finance_ui
nginx --> sim_ui

' Layer 2 to Layer 3: UI to Cache
researcher_ui --> redis_session
org_ui --> redis_session
admin_ui --> redis_session
finance_ui --> redis_session
sim_ui --> redis_session

researcher_ui --> varnish
org_ui --> varnish
admin_ui --> varnish
finance_ui --> varnish

' Layer 3 to Layer 4: Cache to Production System
redis_cache --> bug_bounty
redis_cache --> ptaas
redis_cache --> ai_red
redis_cache --> code_review
redis_cache --> live_hack
redis_cache --> bounty_match

' Layer 3 to Layer 5: Cache to Simulation System
redis_cache --> simulation
simulation --> vuln_apps
simulation --> feedback

' Layer 4 & 5 to Layer 6: Business Logic to Operational Services
bug_bounty --> report_mgmt
bug_bounty --> severity
ptaas --> report_mgmt
ai_red --> report_mgmt
code_review --> report_mgmt
live_hack --> notification
bounty_match --> notification

report_mgmt --> wallet
severity --> analytics
wallet --> analytics
notification --> audit

' Layer 6 to Layer 7: Operational Services to Async Processing
notification --> celery_worker
wallet --> celery_worker
analytics --> celery_worker
audit --> celery_worker
celery_worker --> redis_broker

' Layer 7 to Layer 8: Async Processing to Integration & Storage
celery_worker --> payment_gw
celery_worker --> messaging
celery_worker --> external_apis
celery_worker --> minio

' Layer 8 Storage: Local to Cloud
minio --> s3

' Layer 6 & 7 to Layer 9: Services to Data Layer
bug_bounty --> user_db
bug_bounty --> program_db
ptaas --> program_db
ai_red --> program_db
code_review --> reports_db
report_mgmt --> reports_db
wallet --> payments_db
analytics --> analytics_db
audit --> analytics_db

' Simulation System to Isolated Database
simulation --> sim_db
feedback --> sim_db

' Cache to Database
redis_cache --> user_db
redis_cache --> program_db
redis_cache --> reports_db

' ============================================
' NOTES & ANNOTATIONS
' ============================================

note top of nginx
  **Entry Point**
  • Load Balancing
  • SSL Termination
  • Rate Limiting
  • Security Headers
end note

note right of redis_cache
  **NEW: Enhanced Caching**
  • Application Data Cache
  • Session Management
  • Query Result Cache
  • Rate Limiting Store
end note

note right of celery_worker
  **NEW: Async Processing**
  • Email Notifications
  • Payment Processing
  • External API Sync
  • File Processing
  • Report Generation
end note

note right of minio
  **NEW: File Storage**
  • Report Attachments
  • Screenshots/Videos
  • Documents
  • S3-Compatible API
end note

note bottom of sim_db
  **COMPLETELY ISOLATED**
  • Separate Database Instance
  • No Real Organizations
  • No Real Payments
  • Practice Data Only
  • Can be Deployed Separately
end note

note bottom of payment_gw
  **Ethiopian Payment Integration**
  • Telebirr Mobile Money
  • CBE Birr Digital Wallet
  • Bank Transfer APIs
end note

@enduml