@startuml Authentication_Architecture

title Multi-Portal Authentication Architecture\nBug Bounty and Its Simulation Platform

!define RECTANGLE class

skinparam componentStyle rectangle
skinparam linetype ortho

package "Client Layer" {
    [Researcher Portal\nUI] as ResearcherUI
    [Organization Portal\nUI] as OrgUI
    [Admin Portal\nUI] as AdminUI
    [Learning Platform\nUI] as LearnUI
}

package "API Gateway Layer" {
    [API Gateway\n(Nginx/Kong)] as Gateway
    [Rate Limiter] as RateLimit
    [Request Logger] as Logger
}

package "Authentication Service" {
    [Auth Controller] as AuthController
    [JWT Manager] as JWTManager
    [Session Manager] as SessionManager
    [MFA Service] as MFAService
    [SSO Provider\n(SAML/OAuth)] as SSO
}

package "Authorization Service" {
    [RBAC Engine] as RBAC
    [Permission Checker] as PermChecker
    [Role Manager] as RoleManager
}

package "User Management Service" {
    [User Service] as UserService
    [Staff Provisioning] as StaffProv
    [Profile Manager] as ProfileMgr
}

package "Data Layer" {
    database "PostgreSQL" {
        [users] as UsersTable
        [staff_invitations] as InvitationsTable
        [staff_permissions] as PermissionsTable
        [admin_sessions] as SessionsTable
        [audit_logs] as AuditTable
    }
    
    database "Redis Cache" {
        [JWT Blacklist] as JWTBlacklist
        [Session Cache] as SessionCache
        [Rate Limit Data] as RateLimitData
    }
}

package "External Services" {
    [Email Service\n(SendGrid)] as Email
    [SMS Service\n(Twilio)] as SMS
    [Identity Provider\n(Okta/Azure AD)] as IDP
}

' Client to Gateway
ResearcherUI --> Gateway : HTTPS
OrgUI --> Gateway : HTTPS
AdminUI --> Gateway : HTTPS
LearnUI --> Gateway : HTTPS

' Gateway to Services
Gateway --> RateLimit
Gateway --> Logger
Gateway --> AuthController

' Auth Flow
AuthController --> JWTManager
AuthController --> SessionManager
AuthController --> MFAService
AuthController --> SSO
AuthController --> UserService

' Authorization Flow
AuthController --> RBAC
RBAC --> PermChecker
RBAC --> RoleManager

' User Management
UserService --> StaffProv
UserService --> ProfileMgr

' Data Access
UserService --> UsersTable
StaffProv --> InvitationsTable
StaffProv --> PermissionsTable
SessionManager --> SessionsTable
SessionManager --> SessionCache
JWTManager --> JWTBlacklist
AuthController --> AuditTable
RateLimit --> RateLimitData

' External Services
StaffProv --> Email : Staff Invitations
MFAService --> SMS : OTP Codes
SSO --> IDP : SAML/OAuth

note right of Gateway
  Single Entry Point
  - SSL Termination
  - Load Balancing
  - Request Routing
end note

note right of AuthController
  Unified Authentication
  - Email/Password
  - SSO (SAML/OAuth)
  - MFA (TOTP/SMS)
  - JWT Token Generation
end note

note right of RBAC
  Role-Based Access Control
  
  Roles:
  - SUPER_ADMIN
  - ADMIN
  - TRIAGE_SPECIALIST
  - FINANCIAL_OFFICER
  - SUPPORT_STAFF
  - RESEARCHER
  - ORGANIZATION_MEMBER
end note

note right of StaffProv
  Internal Staff Provisioning
  
  Process:
  1. Super Admin creates account
  2. System generates invitation
  3. Email sent to staff
  4. Staff sets password
  5. Account activated
end note

note bottom of UsersTable
  Unified User Table
  
  Fields:
  - user_id (PK)
  - email (unique)
  - password_hash
  - role (enum)
  - is_staff (boolean)
  - status (enum)
  - email_verified
  - last_login_at
end note

@enduml
