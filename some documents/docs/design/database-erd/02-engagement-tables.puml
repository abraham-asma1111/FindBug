@startuml Engagement_Tables_ERD

' ============================================
' DATABASE ERD: Engagement Tables (PTaaS, Code Review, AI Red Teaming, Events)
' Bug Bounty and Its Simulation Platform
' ============================================

!define PK <color:gold><&key></color>
!define FK <color:silver><&link-intact></color>

skinparam linetype ortho
left to right direction

title Engagement Tables - PTaaS, Code Review, AI Red Teaming, Live Events

' PTAAS
entity "ptaas_engagements" as ptaas {
  PK engagement_id : UUID
  FK organization_id : UUID
  FK researcher_id : UUID
  title : VARCHAR(200)
  status : VARCHAR(20)
  budget : DECIMAL(15,2)
}

entity "retest_requests" as retests {
  PK retest_id : UUID
  FK engagement_id : UUID
  status : VARCHAR(20)
  result : VARCHAR(20)
}

' CODE REVIEW
entity "code_review_engagements" as code_reviews {
  PK engagement_id : UUID
  FK organization_id : UUID
  FK reviewer_id : UUID
  title : VARCHAR(200)
  status : VARCHAR(20)
}

entity "code_review_findings" as cr_findings {
  PK finding_id : UUID
  FK engagement_id : UUID
  title : VARCHAR(200)
  severity : VARCHAR(20)
}

' AI RED TEAMING
entity "ai_red_teaming_engagements" as ai_engagements {
  PK engagement_id : UUID
  FK organization_id : UUID
  FK expert_id : UUID
  title : VARCHAR(200)
  status : VARCHAR(20)
}

entity "ai_vulnerability_reports" as ai_reports {
  PK report_id : UUID
  FK engagement_id : UUID
  attack_type : VARCHAR(50)
  severity : VARCHAR(20)
}

' LIVE EVENTS
entity "live_hacking_events" as events {
  PK event_id : UUID
  FK organization_id : UUID
  name : VARCHAR(200)
  status : VARCHAR(20)
  prize_pool : DECIMAL(15,2)
}

entity "event_participations" as participations {
  PK participation_id : UUID
  FK event_id : UUID
  FK researcher_id : UUID
  score : INTEGER
  rank : INTEGER
}

' RELATIONSHIPS
ptaas ||--o{ retests
code_reviews ||--o{ cr_findings
ai_engagements ||--o{ ai_reports
events ||--o{ participations

@enduml
