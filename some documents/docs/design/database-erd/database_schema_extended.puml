}

entity "payment_history" as payment_history {
  PK history_id : UUID
  FK payment_id : UUID
  previous_status : VARCHAR(20)
  new_status : VARCHAR(20)
  changed_by : UUID
  notes : TEXT
  changed_at : TIMESTAMP
}

