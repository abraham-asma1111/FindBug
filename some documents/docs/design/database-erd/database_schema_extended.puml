}

entity "duplicate_detections" as duplicate_detections {
  PK detection_id : UUID
  FK report_id : UUID
  FK duplicate_of : UUID
  similarity_score : DECIMAL(5,2)
  detection_method : VARCHAR(50)
  detected_at : TIMESTAMP
}

