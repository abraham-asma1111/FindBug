@startuml Organization_Types

' ============================================
' Module 2: Organization Types
' FREQ-03, FREQ-04
' ============================================

skinparam classAttributeIconSize 0

class Organization {
    - organizationId: String
    - companyName: String
    - subscriptionType: String
    + createProgram()
    + manageProgram()
}

class AcademicProgram {
    - programId: String
    - name: String
    - type: Enum {Public, Private, VDP}
    + publish()
}

class NonProfitOrganization {
    - programId: String
    - name: String
    - type: Enum {Public, Private, VDP}
    + publish()
}

class FundingAgency {
    - programId: String
    - name: String
    - type: Enum {Public, Private, VDP}
    + publish()
}

class ConsultingAgent {
    - programId: String
    - name: String
    - type: Enum {Public, Private, VDP}
    + publish()
}

class CodeReview {
    - reviewId: String
    - created: DateTime
    + create()
}

Organization <|-- AcademicProgram
Organization <|-- NonProfitOrganization
Organization <|-- FundingAgency
Organization <|-- ConsultingAgent
Organization <|-- CodeReview

@enduml
