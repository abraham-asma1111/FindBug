@startuml Analysis_Class_Model_Complete

' ============================================
' Complete Analysis Class Model
' Bug Bounty and Simulation Platform
' Covers all 48 FREQs and 12 Use Cases
' ============================================

skinparam classAttributeIconSize 0
skinparam class {
    BackgroundColor<<Entity>> LightBlue
    BackgroundColor<<Service>> LightGreen
    BackgroundColor<<Boundary>> LightYellow
}

' ============================================
' CORE USER HIERARCHY (FREQ-01, FREQ-02, UC-01)
' ============================================

class User {
    - userId: String
    - email: String
    - password: String
    - fullName: String
    - status: Enum {Pending, Active, Suspended}
    + login()
    + logout()
    + updateProfile()
    + resetPassword()
}

class Researcher {
    - researcherId: String
    - reputationScore: Decimal
    - skills: List<String>
    - rank: Integer
    + submitReport()
    + joinProgram()
    + viewDashboard()
    + practiceSimulation()
}

class Organization {
    - organizationId: String
    - companyName: String
    - subscriptionType: String
    + createProgram()
    + manageProgram()
    + approveReward()
    + viewAnalytics()
}

class TriageSpecialist {
    - specialistId: String
    - validationCount: Integer
    + validateReport()
    + assignSeverity()
    + deduplicateReport()
}

class FinancialOfficer {
    - officerId: String
    + approveReward()
    + processPayment()
    + viewFinancials()
}

class Administrator {
    - adminId: String
    - accessLevel: String
    + manageUsers()
    + configureSystem()
    + viewAuditLog()
    + moderatePrograms()
}

' User inheritance
User <|-- Researcher
User <|-- Organization
User <|-- TriageSpecialist
User <|-- FinancialOfficer
User <|-- Administrator

' ============================================
' ORGANIZATION TYPES (FREQ-03, FREQ-04)
' ============================================

class AcademicProgram {
    - programId: String
    - name: String
    - type: Enum {Public, Private, VDP}
    + publish()
}

class NonProfitOrganization {
    - programId: String
    - name: String
    - type: Enum {Public, Private, VDP}
    + publish()
}

class FundingAgency {
    - programId: String
    - name: String
    - type: Enum {Public, Private, VDP}
    + publish()
}

class ConsultingAgent {
    - programId: String
    - name: String
    - type: Enum {Public, Private, VDP}
    + publish()
}

class CodeReview {
    - reviewId: String
    - created: DateTime
    + create()
    + closeReview()
}

Organization <|-- AcademicProgram
Organization <|-- NonProfitOrganization
Organization <|-- FundingAgency
Organization <|-- ConsultingAgent
Organization <|-- CodeReview

' ============================================
' BOUNTY PROGRAM (FREQ-03, FREQ-04, UC-04)
' ============================================

class BountyProgram {
    - programId: String
    - name: String
    - description: String
    - type: Enum {Public, Private, VDP}
    - status: Enum {Draft, Active, Paused, Closed}
    - createdDate: DateTime
    + create()
    + publish()
    + pause()
    + close()
}

class ProgramScope {
    - scopeId: String
    - inScopeAssets: List<String>
    - outOfScopeAssets: List<String>
    - rules: String
    + defineScope()
    + updateScope()
}

class RewardTier {
    - tierId: String
    - severity: Enum {Critical, High, Medium, Low}
    - minAmount: Decimal
    - maxAmount: Decimal
    + setReward()
}

Organization "1" -- "0..*" BountyProgram : creates
BountyProgram "1" -- "1" ProgramScope : has
BountyProgram "1" -- "1..*" RewardTier : defines

' ============================================
' VULNERABILITY REPORTING (FREQ-05, FREQ-06, UC-02)
' ============================================

class VulnerabilityReport {
    - reportId: String
    - title: String
    - description: String
    - stepsToReproduce: String
    - impact: String
    - suggestedSeverity: Enum
    - status: Enum {New, Triaged, Valid, Invalid, Duplicate, Resolved}
    - submittedDate: DateTime
    + submit()
    + update()
    + attachEvidence()
}

class Attachment {
    - attachmentId: String
    - fileName: String
    - fileType: String
    - fileUrl: String
    + upload()
}

Researcher "1" -- "0..*" VulnerabilityReport : submits
BountyProgram "1" -- "0..*" VulnerabilityReport : receives
VulnerabilityReport "1" -- "0..*" Attachment : contains

' ============================================
' TRIAGE & VALIDATION (FREQ-07, FREQ-08, UC-03)
' ============================================

class TriageQueue {
    - queueId: String
    - pendingCount: Integer
    + addReport()
    + assignToSpecialist()
}

class ValidationResult {
    - validationId: String
    - isValid: Boolean
    - isDuplicate: Boolean
    - comments: String
    - validatedDate: DateTime
    + validate()
}

class SeverityRating {
    - ratingId: String
    - severity: Enum {Critical, High, Medium, Low, Info}
    - vrtCategory: String
    - justification: String
    + assignSeverity()
}

TriageSpecialist "1" -- "0..*" TriageQueue : manages
TriageQueue "1" -- "0..*" VulnerabilityReport : contains
TriageSpecialist "1" -- "0..*" ValidationResult : creates
VulnerabilityReport "1" -- "0..1" ValidationResult : has
VulnerabilityReport "1" -- "0..1" SeverityRating : assigned

' ============================================
' BOUNTY PAYMENT (FREQ-10, FREQ-11, FREQ-20, UC-05)
' ============================================

class BountyPayment {
    - paymentId: String
    - amount: Decimal
    - platformCommission: Decimal
    - status: Enum {Pending, Approved, Processed, Failed}
    - approvedDate: DateTime
    + approve()
    + process()
}

class PayoutRequest {
    - requestId: String
    - requestedAmount: Decimal
    - requestDate: DateTime
    - status: Enum {Pending, Processing, Completed, Rejected}
    + create()
    + process()
}

class Transaction {
    - transactionId: String
    - amount: Decimal
    - transactionDate: DateTime
    - paymentMethod: String
    - status: String
    + record()
}

class PaymentGateway {
    - gatewayId: String
    - gatewayName: String
    - apiKey: String
    + processPayment()
    + verifyTransaction()
}

VulnerabilityReport "1" -- "0..1" BountyPayment : rewards
FinancialOfficer "1" -- "0..*" BountyPayment : approves
Researcher "1" -- "0..*" PayoutRequest : requests
BountyPayment "1" -- "0..1" Transaction : generates
PaymentGateway "1" -- "0..*" Transaction : processes

' ============================================
' RESEARCHER MATCHING (FREQ-16, FREQ-32, FREQ-39)
' ============================================

class BountyMatch {
    - matchId: String
    - matchScore: Decimal
    - matchDate: DateTime
    + matchResearcher()
    + recommendProgram()
}

class MatchingCriteria {
    - criteriaId: String
    - requiredSkills: List<String>
    - minReputation: Integer
    - availability: Boolean
    + evaluate()
}

BountyMatch "1" -- "1" Researcher : matches
BountyMatch "1" -- "1" BountyProgram : to
BountyMatch "1" -- "1" MatchingCriteria : uses

' ============================================
' SIMULATION ENVIRONMENT (FREQ-23-28, UC-07)
' ============================================

class SimulatedEnvironment {
    - simulationId: String
    - difficultyLevel: Enum {Beginner, Intermediate, Advanced}
    - targetName: String
    - vulnerabilityType: String
    + launch()
    + submitReport()
    + provideFeedback()
}

class SimulationReport {
    - reportId: String
    - findings: String
    - score: Integer
    - feedback: String
    + submit()
}

Researcher "1" -- "0..*" SimulatedEnvironment : practices
SimulatedEnvironment "1" -- "0..*" SimulationReport : generates

' ============================================
' PTaaS (FREQ-29-40)
' ============================================

class PTaaSEngagement {
    - engagementId: String
    - scope: String
    - methodology: String
    - duration: Integer
    - status: Enum {Scheduled, InProgress, Completed}
    - pricingModel: Enum {Fixed, Subscription}
    + create()
    + assignResearchers()
    + trackProgress()
}

class TestingMethodology {
    - methodologyId: String
    - name: String {OWASP, PTES}
    - checklist: List<String>
    + apply()
}

class RetestRequest {
    - retestId: String
    - originalFindingId: String
    - requestDate: DateTime
    - status: Enum {Pending, Approved, Completed}
    + create()
    + approve()
}

Organization "1" -- "0..*" PTaaSEngagement : requests
PTaaSEngagement "1" -- "1" TestingMethodology : follows
PTaaSEngagement "1" -- "0..*" Researcher : assigns
PTaaSEngagement "1" -- "0..*" VulnerabilityReport : produces
PTaaSEngagement "1" -- "0..*" RetestRequest : allows
BountyMatch "1" -- "0..*" PTaaSEngagement : matches

' ============================================
' EXPERT CODE REVIEW (FREQ-41, UC-08)
' ============================================

class CodeReviewEngagement {
    - reviewId: String
    - repositoryUrl: String
    - codeScope: String
    - status: Enum {Pending, InProgress, Completed}
    + create()
    + assignReviewers()
}

class CodeReviewFinding {
    - findingId: String
    - issueType: String
    - severity: String
    - lineNumber: Integer
    - recommendation: String
    + report()
}

Organization "1" -- "0..*" CodeReviewEngagement : initiates
CodeReviewEngagement "1" -- "0..*" Researcher : assigns
CodeReviewEngagement "1" -- "0..*" CodeReviewFinding : produces

' ============================================
' SSDLC INTEGRATION (FREQ-42, UC-09)
' ============================================

class ExternalIntegration {
    - integrationId: String
    - toolName: String
    - apiKey: String
    - status: Enum {Active, Inactive}
    + configure()
    + sync()
}

class JiraConnector {
    - connectorId: String
    - jiraUrl: String
    - projectKey: String
    + syncIssues()
    + createIssue()
}

class GitHubConnector {
    - connectorId: String
    - repoUrl: String
    - accessToken: String
    + syncIssues()
    + createIssue()
}

class SyncLog {
    - logId: String
    - syncDate: DateTime
    - status: Enum {Success, Failed, Retry}
    - errorMessage: String
    + record()
}

ExternalIntegration <|-- JiraConnector
ExternalIntegration <|-- GitHubConnector
Organization "1" -- "0..*" ExternalIntegration : configures
ExternalIntegration "1" -- "0..*" SyncLog : logs
VulnerabilityReport "1" -- "0..*" ExternalIntegration : syncs

' ============================================
' LIVE HACKING EVENTS (FREQ-43, FREQ-44, UC-10)
' ============================================

class LiveHackingEvent {
    - eventId: String
    - name: String
    - startTime: DateTime
    - endTime: DateTime
    - scope: String
    - status: Enum {Scheduled, Active, Completed}
    + schedule()
    + invite()
    + close()
}

class EventParticipation {
    - participationId: String
    - joinedAt: DateTime
    - submissionCount: Integer
    + join()
    + submit()
}

class EventMetrics {
    - metricsId: String
    - totalBugsFound: Integer
    - participationRate: Decimal
    - totalRewards: Decimal
    + calculate()
    + report()
}

Organization "1" -- "0..*" LiveHackingEvent : hosts
Researcher "1" -- "0..*" EventParticipation : participates
LiveHackingEvent "1" -- "0..*" EventParticipation : has
LiveHackingEvent "1" -- "0..*" VulnerabilityReport : receives
LiveHackingEvent "1" -- "1" EventMetrics : tracks

' ============================================
' AI RED TEAMING (FREQ-45-48, UC-11)
' ============================================

class AIRedTeamingEngagement {
    - engagementId: String
    - targetAISystem: String
    - testingEnvironment: String
    - ethicalGuidelines: String
    - status: Enum {Pending, Active, Completed}
    + create()
    + assignExperts()
}

class AIVulnerabilityReport {
    - reportId: String
    - inputPrompt: String
    - modelResponse: String
    - attackType: Enum {PromptInjection, Jailbreak, DataLeakage}
    - classification: Enum {Security, Safety, Trust}
    - impact: String
    + submit()
}

class AITestingEnvironment {
    - environmentId: String
    - modelType: String
    - sandboxUrl: String
    - accessControls: String
    + setup()
    + isolate()
}

Organization "1" -- "0..*" AIRedTeamingEngagement : creates
AIRedTeamingEngagement "1" -- "1" AITestingEnvironment : uses
AIRedTeamingEngagement "1" -- "0..*" Researcher : assigns
AIRedTeamingEngagement "1" -- "0..*" AIVulnerabilityReport : produces
BountyMatch "1" -- "0..*" AIRedTeamingEngagement : matches

' ============================================
' KYC/IDENTITY VERIFICATION (UC-12, BR-08)
' ============================================

class KYCVerification {
    - kycId: String
    - status: Enum {Pending, Verified, Rejected}
    - verifiedDate: DateTime
    + submit()
    + verify()
    + reject()
}

class IdentityDocument {
    - documentId: String
    - documentType: Enum {NationalID, Passport}
    - documentNumber: String
    - expiryDate: Date
    - documentUrl: String
    + upload()
    + validate()
}

Researcher "1" -- "0..1" KYCVerification : completes
KYCVerification "1" -- "1..*" IdentityDocument : requires

' ============================================
' COMMUNICATION (FREQ-09, FREQ-12)
' ============================================

class Notification {
    - notificationId: String
    - type: Enum {Email, InPlatform}
    - message: String
    - sentDate: DateTime
    - isRead: Boolean
    + send()
    + markAsRead()
}

class Message {
    - messageId: String
    - subject: String
    - body: String
    - sentDate: DateTime
    + send()
    + reply()
}

class Comment {
    - commentId: String
    - content: String
    - createdDate: DateTime
    + add()
    + edit()
}

User "1" -- "0..*" Notification : receives
User "1" -- "0..*" Message : sends
VulnerabilityReport "1" -- "0..*" Comment : has
User "1" -- "0..*" Comment : writes

' ============================================
' ANALYTICS & DASHBOARD (FREQ-13, FREQ-15, UC-06)
' ============================================

class Dashboard {
    - dashboardId: String
    - userRole: String
    - widgets: List<String>
    + display()
    + customize()
}

class AnalyticsReport {
    - reportId: String
    - reportType: String
    - generatedDate: DateTime
    - data: JSON
    + generate()
    + export()
}

class Metrics {
    - metricId: String
    - metricName: String
    - value: Decimal
    - calculatedDate: DateTime
    + calculate()
}

User "1" -- "1" Dashboard : views
Dashboard "1" -- "0..*" AnalyticsReport : displays
AnalyticsReport "1" -- "0..*" Metrics : contains

' ============================================
' AUDIT & LOGGING (FREQ-17, BR-19)
' ============================================

class AuditLog {
    - logId: String
    - action: String
    - performedBy: String
    - timestamp: DateTime
    - details: String
    + record()
    + query()
}

class ActivityLog {
    - activityId: String
    - activityType: String
    - userId: String
    - timestamp: DateTime
    + log()
}

Administrator "1" -- "0..*" AuditLog : views
User "1" -- "0..*" ActivityLog : generates

@enduml
