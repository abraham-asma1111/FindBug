@startuml Live_Hacking_Events

' ============================================
' Module 10: Live Hacking Events
' FREQ-43, FREQ-44, UC-10
' ============================================

skinparam classAttributeIconSize 0

class Organization {
    - organizationId: String
}

class Researcher {
    - researcherId: String
}

class VulnerabilityReport {
    - reportId: String
}

class LiveHackingEvent {
    - eventId: String
    - name: String
    - startTime: DateTime
    - endTime: DateTime
    - scope: String
    - status: Enum {Scheduled, Active, Completed}
    + schedule()
    + invite()
    + close()
}

class EventParticipation {
    - participationId: String
    - joinedAt: DateTime
    - submissionCount: Integer
    + join()
    + submit()
}

class EventMetrics {
    - metricsId: String
    - totalBugsFound: Integer
    - participationRate: Decimal
    - totalRewards: Decimal
    + calculate()
}

Organization "1" -- "0..*" LiveHackingEvent : hosts
Researcher "1" -- "0..*" EventParticipation : participates
LiveHackingEvent "1" -- "0..*" EventParticipation : has
LiveHackingEvent "1" -- "0..*" VulnerabilityReport : receives
LiveHackingEvent "1" -- "1" EventMetrics : tracks

@enduml
