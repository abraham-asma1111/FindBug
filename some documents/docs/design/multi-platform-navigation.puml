@startuml Multi_Platform_Navigation

title Multi-Platform Navigation & SSO Flow\nBug Bounty and Its Simulation Platform

skinparam componentStyle rectangle
skinparam linetype ortho

' User Entry Point
actor "User" as User

' Authentication Layer
package "Authentication Service" {
    [Login Portal] as Login
    [SSO Manager] as SSO
    [JWT Token Service] as JWT
}

' Main Platform Portals
package "Main Platform (platform.com)" {
    
    package "Researcher Portal" {
        [Researcher Dashboard] as RDash
        [Browse Programs] as RPrograms
        [Submit Reports] as RReports
        [View Earnings] as REarnings
        [Profile & Reputation] as RProfile
    }
    
    package "Organization Portal" {
        [Organization Dashboard] as ODash
        [Manage Programs] as OPrograms
        [Review Reports] as OReports
        [Team Management] as OTeam
        [Analytics] as OAnalytics
    }
    
    package "Admin Portal" {
        [Admin Dashboard] as ADash
        [User Management] as AUsers
        [Staff Management] as AStaff
        [System Config] as AConfig
        [Audit Logs] as AAudit
    }
}

' Learning Platform
package "Learning Platform (learn.platform.com)" {
    [Learning Dashboard] as LDash
    [Browse Challenges] as LChallenges
    [Active Session] as LSession
    [Submit Report] as LReport
    [View Progress] as LProgress
    [Leaderboard] as LLeaderboard
}

' Shared Components
package "Shared Services" {
    [Notifications] as Notify
    [Messages] as Messages
    [Settings] as Settings
    [Help & Support] as Help
}

' User Login Flow
User --> Login : 1. Access Platform

' Role-Based Routing
Login --> JWT : 2. Authenticate
JWT --> SSO : 3. Generate Token

SSO -down-> RDash : 4a. If role=RESEARCHER
SSO -down-> ODash : 4b. If role=ORGANIZATION
SSO -down-> ADash : 4c. If role=ADMIN/STAFF

' Researcher Navigation
RDash --> RPrograms : Browse
RDash --> RReports : Submit/Track
RDash --> REarnings : Payments
RDash --> RProfile : Profile
RDash -right-> LDash : "Go to Learning" (SSO)

' Organization Navigation
ODash --> OPrograms : Manage
ODash --> OReports : Review
ODash --> OTeam : Team
ODash --> OAnalytics : Analytics

' Admin Navigation
ADash --> AUsers : Users
ADash --> AStaff : Staff
ADash --> AConfig : Config
ADash --> AAudit : Audit

' Learning Platform Navigation
LDash --> LChallenges : Browse
LChallenges --> LSession : Start Challenge
LSession --> LReport : Submit Solution
LDash --> LProgress : Track Progress
LDash --> LLeaderboard : Rankings
LDash -left-> RDash : "Back to Main" (SSO)

' Shared Access
RDash --> Notify
ODash --> Notify
ADash --> Notify
LDash --> Notify

RDash --> Messages
ODash --> Messages

RDash --> Settings
ODash --> Settings
ADash --> Settings
LDash --> Settings

note right of Login
  Single Login URL:
  https://platform.com/login
  
  Credentials validated once
  JWT token with role claims
  Routes to appropriate portal
end note

note right of SSO
  SSO Token Flow:
  1. User clicks "Go to Learning"
  2. Generate short-lived SSO token
  3. Redirect with token
  4. Learning platform validates
  5. Create learning session
  6. No re-authentication needed
end note

note bottom of LDash
  Learning Platform Features:
  - Separate subdomain
  - Same user account
  - Different UI/navigation
  - Isolated environment
  - Skills sync to main profile
end note

note bottom of RDash
  Researcher Journey:
  Main Platform → Learning Platform
  Practice → Earn → Repeat
  
  Skills from learning reflected
  in main platform reputation
end note

@enduml
