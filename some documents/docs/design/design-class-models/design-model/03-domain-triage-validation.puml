@startuml Design_Domain_Triage_Validation

' ============================================
' Design Class Model - Domain Layer
' Module 3: Triage & Validation
' ============================================

skinparam classAttributeIconSize 0

class TriageQueue {
    - queueId: UUID {PK, unique, not null}
    - name: String {max=100, not null}
    - priority: Integer {default=0}
    - pendingCount: Integer {default=0}
    - assignedSpecialistId: UUID {FK->TriageSpecialist.specialistId, nullable}
    - createdAt: DateTime {default=now()}
    - updatedAt: DateTime {default=now()}
    
    + addReport(reportId: UUID): void
    + removeReport(reportId: UUID): void
    + assignToSpecialist(specialistId: UUID): void
    + getNextReport(): VulnerabilityReport
    + reorderQueue(reportIds: List<UUID>): void
    + calculateAverageWaitTime(): Integer
}

class TriageAssignment {
    - assignmentId: UUID {PK, unique, not null}
    - reportId: UUID {FK->VulnerabilityReport.reportId, unique, not null}
    - specialistId: UUID {FK->TriageSpecialist.specialistId, not null}
    - assignedAt: DateTime {default=now()}
    - startedAt: DateTime {nullable}
    - completedAt: DateTime {nullable}
    - status: AssignmentStatus {enum, default=ASSIGNED}
    - timeSpent: Integer {minutes, default=0}
    
    + assign(reportId: UUID, specialistId: UUID): void
    + start(): void
    + complete(): void
    + reassign(newSpecialistId: UUID): void
}

enum AssignmentStatus {
    ASSIGNED
    IN_PROGRESS
    COMPLETED
    REASSIGNED
}

class ValidationResult {
    - validationId: UUID {PK, unique, not null}
    - reportId: UUID {FK->VulnerabilityReport.reportId, unique, not null}
    - specialistId: UUID {FK->TriageSpecialist.specialistId, not null}
    - isValid: Boolean {not null}
    - isDuplicate: Boolean {default=false}
    - duplicateOfReportId: UUID {FK->VulnerabilityReport.reportId, nullable}
    - comments: Text {max=5000, nullable}
    - internalNotes: Text {max=5000, nullable}
    - validatedDate: DateTime {default=now()}
    - reproducible: Boolean {nullable}
    - impactConfirmed: Boolean {nullable}
    - recommendedAction: String {max=500, nullable}
    
    + validate(data: ValidationDTO): ValidationResult throws ValidationException
    + markAsDuplicate(originalReportId: UUID, reason: String): void
    + markAsInvalid(reason: String): void
    + markAsValid(comments: String): void
    + addInternalNote(note: String): void
}

class SeverityRating {
    - ratingId: UUID {PK, unique, not null}
    - reportId: UUID {FK->VulnerabilityReport.reportId, unique, not null}
    - severity: SeverityLevel {enum, not null}
    - vrtCategory: String {max=100, not null}
    - vrtSubcategory: String {max=100, nullable}
    - justification: Text {max=2000, not null}
    - cvssVector: String {max=100, nullable}
    - cvssScore: Decimal(3,1) {min=0, max=10, nullable}
    - assignedBy: UUID {FK->TriageSpecialist.specialistId, not null}
    - assignedAt: DateTime {default=now()}
    - previousSeverity: SeverityLevel {enum, nullable}
    - changedReason: Text {max=1000, nullable}
    
    + assignSeverity(severity: SeverityLevel, justification: String): void throws ValidationException
    + changeSeverity(newSeverity: SeverityLevel, reason: String): void
    + calculateCVSS(vector: String): Decimal
    + validateVRT(): Boolean
}

class DuplicateDetection {
    - detectionId: UUID {PK, unique, not null}
    - reportId: UUID {FK->VulnerabilityReport.reportId, not null}
    - potentialDuplicates: JSON {array of UUIDs, nullable}
    - similarityScore: Decimal(5,2) {min=0, max=100}
    - detectedAt: DateTime {default=now()}
    - algorithm: String {max=50, default='text_similarity'}
    - confirmedDuplicate: Boolean {nullable}
    
    + detectDuplicates(reportId: UUID): List<UUID>
    + calculateSimilarity(report1: UUID, report2: UUID): Decimal
    + confirmDuplicate(originalReportId: UUID): void
    + dismissDuplicate(): void
}

class TriageMetrics {
    - metricsId: UUID {PK, unique, not null}
    - specialistId: UUID {FK->TriageSpecialist.specialistId, unique, not null}
    - totalReportsTriaged: Integer {default=0}
    - validReports: Integer {default=0}
    - invalidReports: Integer {default=0}
    - duplicateReports: Integer {default=0}
    - averageTriageTime: Integer {minutes, default=0}
    - accuracyRate: Decimal(5,2) {min=0, max=100}
    - lastUpdated: DateTime {default=now()}
    
    + updateMetrics(): void
    + calculateAccuracy(): Decimal
    + calculateAverageTime(): Integer
}

' Relationships
TriageQueue "1" -- "0..*" TriageAssignment : contains
TriageAssignment "1" -- "1" VulnerabilityReport : assigns
VulnerabilityReport "1" -- "0..1" ValidationResult : has
VulnerabilityReport "1" -- "0..1" SeverityRating : assigned
VulnerabilityReport "1" -- "0..1" DuplicateDetection : analyzed
TriageSpecialist "1" -- "1" TriageMetrics : tracks

@enduml
