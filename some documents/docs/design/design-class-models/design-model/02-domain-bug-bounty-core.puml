@startuml Design_Domain_Bug_Bounty_Core

' ============================================
' Design Class Model - Domain Layer
' Module 2: Bug Bounty Core (Programs & Reports)
' ============================================

skinparam classAttributeIconSize 0

class BountyProgram {
    - programId: UUID {PK, unique, not null}
    - organizationId: UUID {FK->Organization.organizationId, not null}
    - name: String {max=255, not null}
    - description: Text {max=5000, not null}
    - type: ProgramType {enum, default=PUBLIC}
    - status: ProgramStatus {enum, default=DRAFT}
    - createdDate: DateTime {default=now(), not null}
    - publishedDate: DateTime {nullable}
    - pausedDate: DateTime {nullable}
    - closedDate: DateTime {nullable}
    - startDate: DateTime {nullable}
    - endDate: DateTime {nullable}
    - totalReportsReceived: Integer {default=0}
    - totalBountiesPaid: Decimal(15,2) {default=0.0}
    - averageResponseTime: Integer {hours, default=0}
    - disclosurePolicy: Text {max=2000, nullable}
    
    + create(data: ProgramDTO): BountyProgram throws ValidationException
    + publish(): void throws InvalidStateException
    + pause(reason: String): void
    + resume(): void
    + close(reason: String): void
    + updateScope(scope: ProgramScopeDTO): void throws ValidationException
    + addRewardTier(tier: RewardTierDTO): void
    + inviteResearcher(researcherId: UUID): void throws ResearcherNotFoundException
    + calculateMetrics(): ProgramMetricsDTO
}

enum ProgramType {
    PUBLIC
    PRIVATE
    INVITE_ONLY
    VDP
}

enum ProgramStatus {
    DRAFT
    ACTIVE
    PAUSED
    CLOSED
    ARCHIVED
}

class ProgramScope {
    - scopeId: UUID {PK, unique, not null}
    - programId: UUID {FK->BountyProgram.programId, unique, not null}
    - inScopeAssets: JSON {array of objects, not null}
    - outOfScopeAssets: JSON {array of strings, nullable}
    - rules: Text {max=10000, not null}
    - allowedVulnerabilityTypes: JSON {array of strings, nullable}
    - prohibitedActions: JSON {array of strings, nullable}
    - testingGuidelines: Text {max=5000, nullable}
    - updatedAt: DateTime {default=now()}
    
    + defineScope(data: ScopeDTO): void throws ValidationException
    + updateScope(data: ScopeDTO): void
    + addAsset(asset: AssetDTO): void
    + removeAsset(assetId: String): void
    + validateAsset(url: String): Boolean
}

class RewardTier {
    - tierId: UUID {PK, unique, not null}
    - programId: UUID {FK->BountyProgram.programId, not null}
    - severity: SeverityLevel {enum, not null}
    - minAmount: Decimal(15,2) {min=0, not null}
    - maxAmount: Decimal(15,2) {min=0, not null}
    - currency: String {max=3, default='USD'}
    - description: String {max=500, nullable}
    - createdAt: DateTime {default=now()}
    
    + setReward(severity: SeverityLevel, min: Decimal, max: Decimal): void throws ValidationException
    + calculateReward(impact: String): Decimal
    + validate(): Boolean
}

enum SeverityLevel {
    CRITICAL
    HIGH
    MEDIUM
    LOW
    INFO
}

class VulnerabilityReport {
    - reportId: UUID {PK, unique, not null}
    - programId: UUID {FK->BountyProgram.programId, not null}
    - researcherId: UUID {FK->Researcher.researcherId, not null}
    - title: String {max=255, not null}
    - description: Text {max=10000, not null}
    - stepsToReproduce: Text {max=10000, not null}
    - impact: Text {max=5000, not null}
    - suggestedSeverity: SeverityLevel {enum, not null}
    - actualSeverity: SeverityLevel {enum, nullable}
    - status: ReportStatus {enum, default=NEW}
    - submittedDate: DateTime {default=now(), not null}
    - triagedDate: DateTime {nullable}
    - resolvedDate: DateTime {nullable}
    - vulnerabilityType: String {max=100, nullable}
    - affectedUrl: String {max=500, nullable}
    - cvssScore: Decimal(3,1) {min=0, max=10, nullable}
    - cweId: String {max=20, nullable}
    - isDuplicate: Boolean {default=false}
    - duplicateOfReportId: UUID {FK->VulnerabilityReport.reportId, nullable}
    - viewCount: Integer {default=0}
    
    + submit(data: ReportDTO): VulnerabilityReport throws ValidationException
    + update(data: ReportDTO): void throws InvalidStateException
    + attachEvidence(file: File): Attachment throws FileUploadException
    + addComment(userId: UUID, comment: String): Comment
    + changeStatus(newStatus: ReportStatus, reason: String): void
    + markAsDuplicate(originalReportId: UUID): void
    + calculateCVSS(): Decimal
}

enum ReportStatus {
    NEW
    TRIAGED
    IN_REVIEW
    VALID
    INVALID
    DUPLICATE
    INFORMATIVE
    RESOLVED
    WONT_FIX
    CLOSED
}

class Attachment {
    - attachmentId: UUID {PK, unique, not null}
    - reportId: UUID {FK->VulnerabilityReport.reportId, not null}
    - fileName: String {max=255, not null}
    - fileType: String {max=100, not null}
    - fileSize: Integer {bytes, max=52428800}
    - fileUrl: String {max=500, not null}
    - uploadedAt: DateTime {default=now()}
    - uploadedBy: UUID {FK->User.userId, not null}
    - mimeType: String {max=100, not null}
    - isScreenshot: Boolean {default=false}
    - isVideo: Boolean {default=false}
    - isPOC: Boolean {default=false}
    
    + upload(file: File): String throws FileUploadException, FileSizeExceededException
    + validate(): Boolean
    + generateThumbnail(): String
    + delete(): void
}

class Comment {
    - commentId: UUID {PK, unique, not null}
    - reportId: UUID {FK->VulnerabilityReport.reportId, not null}
    - userId: UUID {FK->User.userId, not null}
    - content: Text {max=5000, not null}
    - isInternal: Boolean {default=false}
    - createdAt: DateTime {default=now()}
    - updatedAt: DateTime {default=now()}
    - editedBy: UUID {FK->User.userId, nullable}
    - parentCommentId: UUID {FK->Comment.commentId, nullable}
    
    + add(userId: UUID, content: String, isInternal: Boolean): Comment throws ValidationException
    + edit(content: String, editorId: UUID): void
    + delete(): void
    + reply(userId: UUID, content: String): Comment
}

class ProgramInvitation {
    - invitationId: UUID {PK, unique, not null}
    - programId: UUID {FK->BountyProgram.programId, not null}
    - researcherId: UUID {FK->Researcher.researcherId, not null}
    - invitedBy: UUID {FK->Organization.organizationId, not null}
    - invitedAt: DateTime {default=now()}
    - status: InvitationStatus {enum, default=PENDING}
    - acceptedAt: DateTime {nullable}
    - rejectedAt: DateTime {nullable}
    - expiresAt: DateTime {not null}
    - message: Text {max=1000, nullable}
    
    + send(): void throws ResearcherNotFoundException
    + accept(): void throws ExpiredInvitationException
    + reject(reason: String): void
    + resend(): void
}

enum InvitationStatus {
    PENDING
    ACCEPTED
    REJECTED
    EXPIRED
    CANCELLED
}

' Relationships
BountyProgram "1" -- "1" ProgramScope : has
BountyProgram "1" -- "1..*" RewardTier : defines
BountyProgram "1" -- "0..*" VulnerabilityReport : receives
BountyProgram "1" -- "0..*" ProgramInvitation : sends
VulnerabilityReport "1" -- "0..*" Attachment : contains
VulnerabilityReport "1" -- "0..*" Comment : has
Comment "0..1" -- "0..*" Comment : replies

@enduml
