@startuml Audit_Logging_Design

' ============================================
' DESIGN CLASS MODEL: Audit & Logging System
' Bug Bounty and Its Simulation Platform
' Coverage: FREQ-17, BR-19
' ============================================

title Audit & Logging System - Design Class Model

' ============================================
' ENUMS
' ============================================

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  SUBMIT
  VALIDATE
  DISPUTE
  RESOLVE
  PAYMENT
  WITHDRAWAL
  EXPORT
  IMPORT
}

enum AuditEntity {
  USER
  REPORT
  PROGRAM
  PAYMENT
  WITHDRAWAL
  ENGAGEMENT
  COMMENT
  DOCUMENT
  INTEGRATION
  SETTINGS
}

enum LogLevel {
  DEBUG
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum LogCategory {
  SECURITY
  PAYMENT
  API
  DATABASE
  SYSTEM
  BUSINESS
}

' ============================================
' DOMAIN CLASSES
' ============================================

class AuditLog {
  + audit_id: UUID <<PK>>
  + user_id: UUID <<FK>>
  + action: AuditAction <<not null>>
  + entity_type: AuditEntity <<not null>>
  + entity_id: UUID <<not null>>
  + old_values: JSON
  + new_values: JSON
  + ip_address: String{max=45}
  + user_agent: String{max=500}
  + request_id: UUID
  + created_at: DateTime <<default=NOW>> <<indexed>>
  --
  + getChanges(): Dict
  + getDiff(): String
  + export(): JSON
}


class ActivityLog {
  + activity_id: UUID <<PK>>
  + user_id: UUID <<FK>> <<not null>>
  + action: String{max=100} <<not null>>
  + description: Text
  + metadata: JSON
  + ip_address: String{max=45}
  + created_at: DateTime <<default=NOW>> <<indexed>>
  --
  + getTimeline(): List<ActivityLog>
  + filterByDateRange(start: DateTime, end: DateTime): List<ActivityLog>
}

class SystemLog {
  + log_id: UUID <<PK>>
  + level: LogLevel <<not null>>
  + category: LogCategory <<not null>>
  + message: Text <<not null>>
  + exception: Text
  + stack_trace: Text
  + context: JSON
  + request_id: UUID
  + created_at: DateTime <<default=NOW>> <<indexed>>
  --
  + isError(): Boolean
  + isCritical(): Boolean
  + getRelatedLogs(): List<SystemLog>
}

class SecurityEvent {
  + event_id: UUID <<PK>>
  + user_id: UUID <<FK>>
  + event_type: String{max=100} <<not null>>
  + severity: String{max=20} <<not null>>
  + description: Text <<not null>>
  + ip_address: String{max=45} <<not null>>
  + user_agent: String{max=500}
  + is_blocked: Boolean <<default=false>>
  + metadata: JSON
  + created_at: DateTime <<default=NOW>> <<indexed>>
  --
  + block(): void
  + alert(): void
  + isAnomaly(): Boolean
}

class LoginHistory {
  + login_id: UUID <<PK>>
  + user_id: UUID <<FK>> <<not null>>
  + ip_address: String{max=45} <<not null>>
  + user_agent: String{max=500}
  + location: String{max=200}
  + is_successful: Boolean <<not null>>
  + failure_reason: String{max=200}
  + mfa_used: Boolean <<default=false>>
  + session_id: UUID
  + created_at: DateTime <<default=NOW>> <<indexed>>
  --
  + detectAnomaly(): Boolean
  + getRecentLogins(days: Integer): List<LoginHistory>
}

class DataExport {
  + export_id: UUID <<PK>>
  + user_id: UUID <<FK>> <<not null>>
  + export_type: String{max=50} <<not null>>
  + format: String{max=20} <<not null>>
  + filters: JSON
  + file_path: String{max=500}
  + file_size: BigInteger
  + status: String{max=20} <<default=PENDING>>
  + expires_at: DateTime
  + created_at: DateTime <<default=NOW>>
  + completed_at: DateTime
  --
  + generate(): void
  + download(): String
  + cleanup(): void
}

class ComplianceReport {
  + report_id: UUID <<PK>>
  + report_type: String{max=100} <<not null>>
  + period_start: DateTime <<not null>>
  + period_end: DateTime <<not null>>
  + data: JSON <<not null>>
  + file_path: String{max=500}
  + generated_by: UUID <<FK>> <<not null>>
  + generated_at: DateTime <<default=NOW>>
  --
  + generateGDPRReport(): void
  + generateAuditTrail(): void
  + export(): String
}

class APIRequestLog {
  + request_id: UUID <<PK>>
  + user_id: UUID <<FK>>
  + method: String{max=10} <<not null>>
  + endpoint: String{max=500} <<not null>>
  + status_code: Integer <<not null>>
  + request_body: Text
  + response_body: Text
  + ip_address: String{max=45}
  + user_agent: String{max=500}
  + duration_ms: Integer
  + created_at: DateTime <<default=NOW>> <<indexed>>
  --
  + isError(): Boolean
  + getAverageResponseTime(): Integer
}

class RateLimitLog {
  + log_id: UUID <<PK>>
  + user_id: UUID <<FK>>
  + ip_address: String{max=45} <<not null>>
  + endpoint: String{max=500} <<not null>>
  + request_count: Integer <<not null>>
  + limit: Integer <<not null>>
  + window_start: DateTime <<not null>>
  + window_end: DateTime <<not null>>
  + is_blocked: Boolean <<default=false>>
  + created_at: DateTime <<default=NOW>>
  --
  + isLimitExceeded(): Boolean
  + resetWindow(): void
}

' ============================================
' RELATIONSHIPS
' ============================================

AuditLog "0..*" --> "0..1" User : performed_by
ActivityLog "0..*" --> "1" User : performed_by
SecurityEvent "0..*" --> "0..1" User : related_to
LoginHistory "0..*" --> "1" User : login_attempts
DataExport "0..*" --> "1" User : requested_by
ComplianceReport "0..*" --> "1" User : generated_by
APIRequestLog "0..*" --> "0..1" User : made_by
RateLimitLog "0..*" --> "0..1" User : tracked_for

' ============================================
' NOTES
' ============================================

note right of AuditLog
  Comprehensive audit trail
  - All CRUD operations
  - Before/after values
  - User attribution
  - IP tracking
  
  Retention: 7 years (compliance)
  
  Indexes:
  - user_id, created_at
  - entity_type, entity_id
  - action, created_at
end note

note right of ActivityLog
  User activity tracking
  - Timeline view
  - User behavior analysis
  - Feature usage tracking
  
  Retention: 2 years
end note

note right of SystemLog
  Application logging
  - Error tracking
  - Performance monitoring
  - Debug information
  
  Levels: DEBUG, INFO, WARNING,
  ERROR, CRITICAL
  
  Retention: 90 days
end note

note right of SecurityEvent
  Security monitoring
  - Failed login attempts
  - Suspicious activities
  - Access violations
  - Rate limit breaches
  
  Triggers alerts for:
  - 5+ failed logins
  - Unusual IP locations
  - Permission violations
end note

note right of LoginHistory
  Authentication tracking
  - Login success/failure
  - MFA usage
  - Location tracking
  - Session management
  
  Anomaly detection:
  - New device/location
  - Unusual time
  - Multiple IPs
end note

note right of DataExport
  GDPR compliance
  - User data export
  - Right to portability
  - Auto-cleanup after 7 days
  
  Export types:
  - Personal data
  - Reports
  - Payments
  - Activity history
end note

note right of ComplianceReport
  Regulatory compliance
  - GDPR reports
  - Audit trails
  - Access logs
  - Data processing records
  
  Generated quarterly
  or on-demand
end note

note right of APIRequestLog
  API monitoring
  - Request/response logging
  - Performance tracking
  - Error analysis
  - Rate limiting data
  
  Retention: 30 days
  
  Indexes:
  - user_id, created_at
  - endpoint, status_code
end note

note right of RateLimitLog
  Rate limiting enforcement
  - Per-user limits
  - Per-IP limits
  - Per-endpoint limits
  
  Default limits:
  - 100 req/min per user
  - 1000 req/hour per IP
  
  Sliding window algorithm
end note

@enduml
