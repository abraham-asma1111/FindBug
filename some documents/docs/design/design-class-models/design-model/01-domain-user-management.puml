@startuml Design_Domain_User_Management

' ============================================
' Design Class Model - Domain Layer
' Module 1: User Management Domain
' ============================================

skinparam classAttributeIconSize 0

class User {
    - userId: UUID {PK, unique, not null}
    - email: String {unique, max=255, not null, regex="^[\\w.-]+@[\\w.-]+\\.\\w+$"}
    - passwordHash: String {bcrypt, length=60, not null}
    - fullName: String {max=100, not null}
    - status: UserStatus {enum, default=PENDING}
    - emailVerified: Boolean {default=false}
    - verificationToken: String {max=255, nullable}
    - resetToken: String {max=255, nullable}
    - resetTokenExpiry: DateTime {nullable}
    - createdAt: DateTime {default=now(), not null}
    - updatedAt: DateTime {default=now(), not null}
    - lastLoginAt: DateTime {nullable}
    
    + login(email: String, password: String): AuthToken throws AuthenticationException
    + logout(token: String): void
    + updateProfile(data: UserProfileDTO): User throws ValidationException
    + resetPassword(email: String): void throws UserNotFoundException
    + verifyEmail(token: String): Boolean throws InvalidTokenException
    + changePassword(oldPassword: String, newPassword: String): void throws AuthenticationException
    - hashPassword(password: String): String
    - validatePassword(password: String): Boolean
    - generateVerificationToken(): String
}

enum UserStatus {
    PENDING
    ACTIVE
    SUSPENDED
    BANNED
}

class Researcher {
    - researcherId: UUID {PK, FK->User.userId}
    - reputationScore: Decimal(10,2) {default=0.0, min=0}
    - skills: JSON {array of strings}
    - rank: Integer {default=0}
    - totalSubmissions: Integer {default=0}
    - validSubmissions: Integer {default=0}
    - totalEarnings: Decimal(15,2) {default=0.0}
    - bio: Text {max=1000, nullable}
    - website: String {max=255, nullable}
    - githubUsername: String {max=100, nullable}
    - twitterHandle: String {max=100, nullable}
    
    + submitReport(programId: UUID, data: ReportDTO): VulnerabilityReport throws ValidationException
    + joinProgram(programId: UUID): void throws ProgramNotFoundException
    + viewDashboard(): ResearcherDashboardDTO
    + practiceSimulation(simulationId: UUID): SimulationSession
    + updateReputation(points: Integer): void
    + calculateRank(): Integer
}

class Organization {
    - organizationId: UUID {PK, FK->User.userId}
    - companyName: String {max=255, not null}
    - industry: String {max=100, nullable}
    - website: String {max=255, nullable}
    - subscriptionType: SubscriptionType {enum, default=FREE}
    - subscriptionStartDate: DateTime {nullable}
    - subscriptionEndDate: DateTime {nullable}
    - totalProgramsCreated: Integer {default=0}
    - totalBountiesPaid: Decimal(15,2) {default=0.0}
    - companySize: String {max=50, nullable}
    - country: String {max=100, nullable}
    
    + createProgram(data: ProgramDTO): BountyProgram throws ValidationException
    + manageProgram(programId: UUID, action: String): void
    + approveReward(reportId: UUID, amount: Decimal): void throws InsufficientFundsException
    + viewAnalytics(): OrganizationAnalyticsDTO
    + upgradeSubscription(type: SubscriptionType): void
}

enum SubscriptionType {
    FREE
    BASIC
    PROFESSIONAL
    ENTERPRISE
}

class TriageSpecialist {
    - specialistId: UUID {PK, FK->User.userId}
    - validationCount: Integer {default=0}
    - specialization: JSON {array of strings}
    - averageResponseTime: Integer {minutes, default=0}
    
    + validateReport(reportId: UUID, result: ValidationDTO): ValidationResult throws ReportNotFoundException
    + assignSeverity(reportId: UUID, severity: SeverityLevel): void
    + deduplicateReport(reportId: UUID, originalReportId: UUID): void
    + addTriageComment(reportId: UUID, comment: String): void
}

class FinancialOfficer {
    - officerId: UUID {PK, FK->User.userId}
    - approvalLimit: Decimal(15,2) {default=10000.0}
    - totalApproved: Decimal(15,2) {default=0.0}
    
    + approveReward(reportId: UUID, amount: Decimal): void throws ApprovalLimitExceededException
    + processPayment(paymentId: UUID): void throws PaymentProcessingException
    + viewFinancials(startDate: Date, endDate: Date): FinancialReportDTO
    + generatePayoutReport(month: Integer, year: Integer): PayoutReportDTO
}

class Administrator {
    - adminId: UUID {PK, FK->User.userId}
    - accessLevel: AdminLevel {enum, default=STANDARD}
    - permissions: JSON {array of strings}
    
    + manageUsers(userId: UUID, action: String): void
    + configureSystem(key: String, value: String): void
    + viewAuditLog(filters: AuditFilterDTO): List<AuditLog>
    + moderatePrograms(programId: UUID, action: String): void
    + suspendUser(userId: UUID, reason: String, duration: Integer): void
    + generateSystemReport(type: String): SystemReportDTO
}

enum AdminLevel {
    STANDARD
    SENIOR
    SUPER_ADMIN
}

class KYCVerification {
    - kycId: UUID {PK, unique}
    - researcherId: UUID {FK->Researcher.researcherId, unique}
    - status: KYCStatus {enum, default=PENDING}
    - submittedAt: DateTime {default=now()}
    - verifiedAt: DateTime {nullable}
    - verifiedBy: UUID {FK->Administrator.adminId, nullable}
    - rejectionReason: Text {max=500, nullable}
    - documentCount: Integer {default=0}
    
    + submit(documents: List<IdentityDocument>): void throws ValidationException
    + verify(adminId: UUID): void
    + reject(adminId: UUID, reason: String): void
    + requestAdditionalDocuments(message: String): void
}

enum KYCStatus {
    PENDING
    UNDER_REVIEW
    VERIFIED
    REJECTED
    ADDITIONAL_INFO_REQUIRED
}

class IdentityDocument {
    - documentId: UUID {PK, unique}
    - kycId: UUID {FK->KYCVerification.kycId}
    - documentType: DocumentType {enum, not null}
    - documentNumber: String {max=100, not null}
    - expiryDate: Date {nullable}
    - documentUrl: String {max=500, not null}
    - uploadedAt: DateTime {default=now()}
    - fileSize: Integer {bytes}
    - mimeType: String {max=100}
    
    + upload(file: File): String throws FileUploadException
    + validate(): Boolean
    + encrypt(): void
}

enum DocumentType {
    NATIONAL_ID
    PASSPORT
    DRIVERS_LICENSE
    PROOF_OF_ADDRESS
}

' Relationships
User <|-- Researcher
User <|-- Organization
User <|-- TriageSpecialist
User <|-- FinancialOfficer
User <|-- Administrator

Researcher "1" -- "0..1" KYCVerification : completes
KYCVerification "1" -- "1..*" IdentityDocument : requires
Administrator "1" -- "0..*" KYCVerification : verifies

@enduml
