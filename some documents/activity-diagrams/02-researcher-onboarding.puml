`@startuml Researcher_Onboarding

' ============================================
' ACTIVITY DIAGRAM: Researcher Onboarding
' Bug Bounty and Its Simulation Platform
' ============================================

title Researcher Registration and KYC - Activity Diagram

|Researcher|
start
:Visit Platform;
:Click "Register as Researcher";
:Fill Registration Form\n(Name, Email, Password);
:Submit Registration;

|System|
:Validate Input Data;

if (Valid Data?) then (yes)
  :Create User Account;
  :Send Verification Email;
else (no)
  :Show Validation Errors;
  |Researcher|
  stop
endif

|Researcher|
:Check Email;
:Click Verification Link;

|System|
:Verify Email Token;
:Activate Account;
:Send Welcome Email;

|Researcher|
:Login to Platform;
:Navigate to Profile;
:Start KYC Process;

:Upload Identity Document\n(ID Card/Passport);
:Upload Proof of Address;
:Fill Personal Details;
:Submit KYC Application;

|System|
:Store Documents in MinIO;
:Create KYC Record;
:Queue for Manual Review;

|Admin|
:Receive KYC Notification;
:Review Documents;
:Verify Identity;

if (Documents Valid?) then (yes)
  :Approve KYC;
  :Update Account Status;
  
  |System|
  :Send Approval Email;
  :Enable Full Platform Access;
  
  |Researcher|
  :Receive Approval;
  :Complete Profile Setup\n(Skills, Bio, Social Links);
  :Browse Programs;
  :Start Bug Hunting;
  stop
  
else (no)
  :Reject KYC;
  :Provide Rejection Reason;
  
  |System|
  :Send Rejection Email;
  
  |Researcher|
  :Receive Rejection;
  
  if (Resubmit?) then (yes)
    :Fix Issues;
    :Resubmit Documents;
    |System|
    :Queue for Review Again;
    |Admin|
  else (no)
    :Account Remains Limited;
    stop
  endif
endif

@enduml`