# Bug Bounty Platform - Environment Variables
# Copy this file to .env and update with your values

# Database (Production)
POSTGRES_PASSWORD=changeme123

# Database (Simulation)
SIMULATION_PASSWORD=simulation123

# Redis
REDIS_PASSWORD=redis123

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@bugbounty.et

# Payment Gateway (Ethiopian)
TELEBIRR_API_KEY=your-telebirr-api-key
TELEBIRR_API_SECRET=your-telebirr-secret
CBE_BIRR_API_KEY=your-cbe-birr-key
CBE_BIRR_API_SECRET=your-cbe-birr-secret

# External Integrations
JIRA_API_TOKEN=your-jira-token
GITHUB_API_TOKEN=your-github-token

# Application Settings
APP_NAME=Bug Bounty Platform
APP_ENV=development
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# File Upload Settings
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,application/pdf

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Celery
CELERY_BROKER_URL=redis://:redis123@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis123@redis:6379/2

# Monitoring (Production)
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_ENABLED=false

# AWS (Production - Future)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=bugbounty-files
