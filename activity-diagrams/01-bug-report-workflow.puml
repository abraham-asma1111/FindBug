@startuml Bug_Report_Workflow

' ============================================
' ACTIVITY DIAGRAM: Bug Report Workflow
' Bug Bounty and Its Simulation Platform
' Team: Niway Tadesse, Abraham Asimamaw, Melkamu Tesfa
' Advisor: Yosef Worku
' ============================================

title Bug Report Submission and Processing - Activity Diagram

|Researcher|
start
:Login to Platform;
:Browse Active Programs;
:Select Target Program;

if (Eligible for Program?) then (yes)
  :Read Program Scope;
  :Identify Vulnerability;
  :Prepare Evidence\n(Screenshots, Videos, PoC);
  :Fill Report Form;
  :Attach Evidence Files;
  :Submit Report;
else (no)
  :Show Eligibility Error;
  stop
endif

|System|
:Validate Submission;
:Upload Files to MinIO;
:Create Report Record;
:Assign Report ID;
:Send Confirmation Email;

|Triage Analyst|
:Receive Notification;
:Review Report Queue;
:Select Report for Triage;
:Analyze Vulnerability;
:Review Evidence;

if (Valid Vulnerability?) then (yes)
  :Calculate CVSS Score;
  :Assign Severity Rating;
  :Mark as "Triaged";
  
  |Organization|
  :Receive Triage Notification;
  :Review Triaged Report;
  :Verify Vulnerability;
  
  if (Accept Report?) then (yes)
    :Set Reward Amount;
    :Mark as "Validated";
    
    |Finance Officer|
    :Review Payment Queue;
    :Approve Payment;
    :Process Reward;
    
    |Researcher|
    :Receive Payment Notification;
    :Check Wallet Balance;
    stop
    
  else (no - Dispute)
    :Submit Dispute Reason;
    |Triage Analyst|
    :Review Dispute;
    :Mediate Resolution;
    stop
  endif
  
else (no - Invalid/Duplicate)
  :Mark as "Rejected";
  :Provide Rejection Reason;
  
  |Researcher|
  :Receive Rejection Notification;
  :Review Feedback;
  stop
endif

@enduml