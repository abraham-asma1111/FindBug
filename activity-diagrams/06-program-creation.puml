@startuml Program_Creation

' ============================================
' ACTIVITY DIAGRAM: Bug Bounty Program Creation
' Bug Bounty and Its Simulation Platform
' ============================================

title Bug Bounty Program Creation - Activity Diagram

|Organization|
start
:Login to Platform;
:Navigate to Programs;
:Click "Create New Program";

:Fill Program Details\n(Name, Description, Type);
:Set Program Duration;
:Define Target Assets\n(Domains, APIs, Mobile Apps);

:Specify In-Scope Items;
:Specify Out-of-Scope Items;

:Define Vulnerability Types\n(XSS, SQLi, CSRF, etc.);

:Set Reward Tiers;
note right
  Critical: $5000
  High: $2000
  Medium: $500
  Low: $100
end note

:Define Eligibility Criteria\n(Reputation, Skills, Location);

:Set Program Rules\n(Disclosure Policy, Testing Rules);

:Upload Program Assets\n(Documentation, Credentials);

|System|
:Validate Program Data;

if (Valid Data?) then (yes)
  :Upload Assets to MinIO;
  :Create Program Record;
  :Create Scope Records;
  :Create Reward Tiers;
  :Assign Program ID;
else (no)
  :Show Validation Errors;
  |Organization|
  :Fix Errors;
  stop
endif

|Organization|
:Review Program Preview;

if (Publish Now?) then (yes)
  :Click "Publish Program";
  
  |System|
  :Set Status = "Active";
  :Index for Search;
  :Send Launch Notifications;
  
  |Researcher|
  :Receive New Program Alert;
  :Browse Program Details;
  
  if (Interested & Eligible?) then (yes)
    :Start Bug Hunting;
    stop
  else (no)
    :Skip Program;
    stop
  endif
  
else (no - Save as Draft)
  :Save as Draft;
  
  |System|
  :Set Status = "Draft";
  :Store Program;
  
  |Organization|
  :Edit Later;
  stop
endif

@enduml